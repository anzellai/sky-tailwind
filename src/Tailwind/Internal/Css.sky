-- Border
-- ============================================================
borderRules =
    [ rule ".border" [ border "1px solid" ]

    -- Border Color
    , rule ".border-0" [ borderWidth "0px" ]

    -- Border Style
    , rule ".border-2" [ borderWidth "2px" ]

    -- Border Radius
    , rule ".border-4" [ borderWidth "4px" ]

    -- Border Collapse (for tables)
