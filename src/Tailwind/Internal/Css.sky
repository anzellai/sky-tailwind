    , rule ".pl-1" [ paddingLeft "0.25rem" ]
    , rule ".pl-2" [ paddingLeft "0.5rem" ]
    , rule ".pl-3" [ paddingLeft "0.75rem" ]
    , rule ".pl-4" [ paddingLeft "1rem" ]
    , rule ".pl-5" [ paddingLeft "1.25rem" ]
    , rule ".pl-6" [ paddingLeft "1.5rem" ]
    , rule ".pl-8" [ paddingLeft "2rem" ]
    , rule ".pl-10" [ paddingLeft "2.5rem" ]
    , rule ".pl-12" [ paddingLeft "3rem" ]
    , rule ".m-0" [ margin "0" ]
    , rule ".m-1" [ margin "0.25rem" ]
    , rule ".m-2" [ margin "0.5rem" ]
    , rule ".m-3" [ margin "0.75rem" ]
    , rule ".m-4" [ margin "1rem" ]
    , rule ".m-5" [ margin "1.25rem" ]
    , rule ".m-6" [ margin "1.5rem" ]
    , rule ".m-8" [ margin "2rem" ]
    , rule ".m-10" [ margin "2.5rem" ]
    , rule ".m-12" [ margin "3rem" ]
    , rule ".m-16" [ margin "4rem" ]
    , rule ".m-20" [ margin "5rem" ]
    , rule ".m-24" [ margin "6rem" ]
    , rule ".m-auto" [ margin "auto" ]
    , rule ".mx-0" [ marginLeft "0" , marginRight "0" ]
    , rule ".mx-1" [ marginLeft "0.25rem" , marginRight "0.25rem" ]
    , rule ".mx-2" [ marginLeft "0.5rem" , marginRight "0.5rem" ]
    , rule ".mx-3" [ marginLeft "0.75rem" , marginRight "0.75rem" ]
    , rule ".mx-4" [ marginLeft "1rem" , marginRight "1rem" ]
    , rule ".mx-5" [ marginLeft "1.25rem" , marginRight "1.25rem" ]
    , rule ".mx-6" [ marginLeft "1.5rem" , marginRight "1.5rem" ]
    , rule ".mx-8" [ marginLeft "2rem" , marginRight "2rem" ]
