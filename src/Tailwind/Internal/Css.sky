module Tailwind.Internal.Css exposing (allRules)

import Sky.Core.Prelude exposing (..)
import Std.Css exposing (..)

allRules : String
allRules =
    stylesheet
        (

-- ============================================================
-- Base Reset
-- ============================================================
        baseRules ++

-- ============================================================
-- Spacing: padding, margin, gap, space
-- ============================================================
        spacingRules ++
        typographyRules ++
        layoutRules ++
        flexRules ++
        gridRules ++
        backgroundRules ++
        borderRules ++
        effectsRules ++
        sizingRules ++
        animationRules ++
        transformsRules ++
        filtersRules ++
        gradientRules ++
        outlineRules ++
        divideRules ++
        ringRules ++
        tableRules ++
        accessibilityRules ++ svgRules ++ interactivityRules ++ stateRules
        )

baseRules =
    [ rule "*, *::before, *::after" [ property "box-sizing" "border-box" ]

    -- Padding X (left + right)
    , rule "body" [ margin (lengthRaw "0") , padding (lengthRaw "0") ]
    ]

spacingRules =
    [ rule ".p-0" [ padding (lengthRaw "0") ]

    -- Padding Y (top + bottom)
    , rule ".p-1" [ padding (lengthRaw "0.25rem") ]

    -- Padding Top
    , rule ".p-2" [ padding (lengthRaw "0.5rem") ]

    -- Padding Right
    , rule ".p-3" [ padding (lengthRaw "0.75rem") ]

    -- Padding Bottom
    , rule ".p-4" [ padding (lengthRaw "1rem") ]

    -- Padding Left
    , rule ".p-5" [ padding (lengthRaw "1.25rem") ]

    -- Margin (all sides)
    , rule ".p-6" [ padding (lengthRaw "1.5rem") ]

    -- Margin X (left + right)
    , rule ".p-8" [ padding (lengthRaw "2rem") ]

    -- Margin Y (top + bottom)
    , rule ".p-10" [ padding (lengthRaw "2.5rem") ]

    -- Margin Top
    , rule ".p-12" [ padding (lengthRaw "3rem") ]

    -- Margin Right
    , rule ".p-16" [ padding (lengthRaw "4rem") ]

    -- Margin Bottom
    , rule ".p-20" [ padding (lengthRaw "5rem") ]

    -- Margin Left
    , rule ".p-24" [ padding (lengthRaw "6rem") ]

    -- Negative margins
    , rule ".px-0" [ paddingLeft (lengthRaw "0") , paddingRight (lengthRaw "0") ]

    -- Gap
    , rule ".px-1" [ paddingLeft (lengthRaw "0.25rem") , paddingRight (lengthRaw "0.25rem") ]

    -- Space between (uses adjacent sibling selector)
    , rule ".px-2" [ paddingLeft (lengthRaw "0.5rem") , paddingRight (lengthRaw "0.5rem") ]
    , rule ".px-3" [ paddingLeft (lengthRaw "0.75rem") , paddingRight (lengthRaw "0.75rem") ]
    , rule ".px-4" [ paddingLeft (lengthRaw "1rem") , paddingRight (lengthRaw "1rem") ]
    , rule ".px-5" [ paddingLeft (lengthRaw "1.25rem") , paddingRight (lengthRaw "1.25rem") ]
    , rule ".px-6" [ paddingLeft (lengthRaw "1.5rem") , paddingRight (lengthRaw "1.5rem") ]
    , rule ".px-8" [ paddingLeft (lengthRaw "2rem") , paddingRight (lengthRaw "2rem") ]
    , rule ".px-10" [ paddingLeft (lengthRaw "2.5rem") , paddingRight (lengthRaw "2.5rem") ]
    , rule ".px-12" [ paddingLeft (lengthRaw "3rem") , paddingRight (lengthRaw "3rem") ]
    , rule ".px-16" [ paddingLeft (lengthRaw "4rem") , paddingRight (lengthRaw "4rem") ]
    , rule ".px-20" [ paddingLeft (lengthRaw "5rem") , paddingRight (lengthRaw "5rem") ]
    , rule ".px-24" [ paddingLeft (lengthRaw "6rem") , paddingRight (lengthRaw "6rem") ]
    , rule ".py-0" [ paddingTop (lengthRaw "0") , paddingBottom (lengthRaw "0") ]
    , rule ".py-1" [ paddingTop (lengthRaw "0.25rem") , paddingBottom (lengthRaw "0.25rem") ]
    , rule ".py-2" [ paddingTop (lengthRaw "0.5rem") , paddingBottom (lengthRaw "0.5rem") ]
    , rule ".py-3" [ paddingTop (lengthRaw "0.75rem") , paddingBottom (lengthRaw "0.75rem") ]
    , rule ".py-4" [ paddingTop (lengthRaw "1rem") , paddingBottom (lengthRaw "1rem") ]
    , rule ".py-5" [ paddingTop (lengthRaw "1.25rem") , paddingBottom (lengthRaw "1.25rem") ]
    , rule ".py-6" [ paddingTop (lengthRaw "1.5rem") , paddingBottom (lengthRaw "1.5rem") ]
    , rule ".py-8" [ paddingTop (lengthRaw "2rem") , paddingBottom (lengthRaw "2rem") ]
    , rule ".py-10" [ paddingTop (lengthRaw "2.5rem") , paddingBottom (lengthRaw "2.5rem") ]
    , rule ".py-12" [ paddingTop (lengthRaw "3rem") , paddingBottom (lengthRaw "3rem") ]
    , rule ".py-16" [ paddingTop (lengthRaw "4rem") , paddingBottom (lengthRaw "4rem") ]
    , rule ".py-20" [ paddingTop (lengthRaw "5rem") , paddingBottom (lengthRaw "5rem") ]
    , rule ".py-24" [ paddingTop (lengthRaw "6rem") , paddingBottom (lengthRaw "6rem") ]
    , rule ".pt-0" [ paddingTop (lengthRaw "0") ]
    , rule ".pt-1" [ paddingTop (lengthRaw "0.25rem") ]
    , rule ".pt-2" [ paddingTop (lengthRaw "0.5rem") ]
    , rule ".pt-3" [ paddingTop (lengthRaw "0.75rem") ]
    , rule ".pt-4" [ paddingTop (lengthRaw "1rem") ]
    , rule ".pt-5" [ paddingTop (lengthRaw "1.25rem") ]
    , rule ".pt-6" [ paddingTop (lengthRaw "1.5rem") ]
    , rule ".pt-8" [ paddingTop (lengthRaw "2rem") ]
    , rule ".pt-10" [ paddingTop (lengthRaw "2.5rem") ]
    , rule ".pt-12" [ paddingTop (lengthRaw "3rem") ]
    , rule ".pt-16" [ paddingTop (lengthRaw "4rem") ]
    , rule ".pt-20" [ paddingTop (lengthRaw "5rem") ]
    , rule ".pt-24" [ paddingTop (lengthRaw "6rem") ]
    , rule ".pr-0" [ paddingRight (lengthRaw "0") ]
    , rule ".pr-1" [ paddingRight (lengthRaw "0.25rem") ]
    , rule ".pr-2" [ paddingRight (lengthRaw "0.5rem") ]
    , rule ".pr-3" [ paddingRight (lengthRaw "0.75rem") ]
    , rule ".pr-4" [ paddingRight (lengthRaw "1rem") ]
    , rule ".pr-5" [ paddingRight (lengthRaw "1.25rem") ]
    , rule ".pr-6" [ paddingRight (lengthRaw "1.5rem") ]
    , rule ".pr-8" [ paddingRight (lengthRaw "2rem") ]
    , rule ".pr-10" [ paddingRight (lengthRaw "2.5rem") ]
    , rule ".pr-12" [ paddingRight (lengthRaw "3rem") ]
    , rule ".pb-0" [ paddingBottom (lengthRaw "0") ]
    , rule ".pb-1" [ paddingBottom (lengthRaw "0.25rem") ]
    , rule ".pb-2" [ paddingBottom (lengthRaw "0.5rem") ]
    , rule ".pb-3" [ paddingBottom (lengthRaw "0.75rem") ]
    , rule ".pb-4" [ paddingBottom (lengthRaw "1rem") ]
    , rule ".pb-5" [ paddingBottom (lengthRaw "1.25rem") ]
    , rule ".pb-6" [ paddingBottom (lengthRaw "1.5rem") ]
    , rule ".pb-8" [ paddingBottom (lengthRaw "2rem") ]
    , rule ".pb-10" [ paddingBottom (lengthRaw "2.5rem") ]
    , rule ".pb-12" [ paddingBottom (lengthRaw "3rem") ]
    , rule ".pl-0" [ paddingLeft (lengthRaw "0") ]
    , rule ".pl-1" [ paddingLeft (lengthRaw "0.25rem") ]
    , rule ".pl-2" [ paddingLeft (lengthRaw "0.5rem") ]
    , rule ".pl-3" [ paddingLeft (lengthRaw "0.75rem") ]
    , rule ".pl-4" [ paddingLeft (lengthRaw "1rem") ]
    , rule ".pl-5" [ paddingLeft (lengthRaw "1.25rem") ]
    , rule ".pl-6" [ paddingLeft (lengthRaw "1.5rem") ]
    , rule ".pl-8" [ paddingLeft (lengthRaw "2rem") ]
    , rule ".pl-10" [ paddingLeft (lengthRaw "2.5rem") ]
    , rule ".pl-12" [ paddingLeft (lengthRaw "3rem") ]
    , rule ".m-0" [ margin (lengthRaw "0") ]
    , rule ".m-1" [ margin (lengthRaw "0.25rem") ]
    , rule ".m-2" [ margin (lengthRaw "0.5rem") ]
    , rule ".m-3" [ margin (lengthRaw "0.75rem") ]
    , rule ".m-4" [ margin (lengthRaw "1rem") ]
    , rule ".m-5" [ margin (lengthRaw "1.25rem") ]
    , rule ".m-6" [ margin (lengthRaw "1.5rem") ]
    , rule ".m-8" [ margin (lengthRaw "2rem") ]
    , rule ".m-10" [ margin (lengthRaw "2.5rem") ]
    , rule ".m-12" [ margin (lengthRaw "3rem") ]
    , rule ".m-16" [ margin (lengthRaw "4rem") ]
    , rule ".m-20" [ margin (lengthRaw "5rem") ]
    , rule ".m-24" [ margin (lengthRaw "6rem") ]
    , rule ".m-auto" [ margin (lengthRaw "auto") ]
    , rule ".mx-0" [ marginLeft (lengthRaw "0") , marginRight (lengthRaw "0") ]
    , rule ".mx-1" [ marginLeft (lengthRaw "0.25rem") , marginRight (lengthRaw "0.25rem") ]
    , rule ".mx-2" [ marginLeft (lengthRaw "0.5rem") , marginRight (lengthRaw "0.5rem") ]
    , rule ".mx-3" [ marginLeft (lengthRaw "0.75rem") , marginRight (lengthRaw "0.75rem") ]
    , rule ".mx-4" [ marginLeft (lengthRaw "1rem") , marginRight (lengthRaw "1rem") ]
    , rule ".mx-5" [ marginLeft (lengthRaw "1.25rem") , marginRight (lengthRaw "1.25rem") ]
    , rule ".mx-6" [ marginLeft (lengthRaw "1.5rem") , marginRight (lengthRaw "1.5rem") ]
    , rule ".mx-8" [ marginLeft (lengthRaw "2rem") , marginRight (lengthRaw "2rem") ]
    , rule ".mx-10" [ marginLeft (lengthRaw "2.5rem") , marginRight (lengthRaw "2.5rem") ]
    , rule ".mx-12" [ marginLeft (lengthRaw "3rem") , marginRight (lengthRaw "3rem") ]
    , rule ".mx-auto" [ marginLeft (lengthRaw "auto") , marginRight (lengthRaw "auto") ]
    , rule ".my-0" [ marginTop (lengthRaw "0") , marginBottom (lengthRaw "0") ]
    , rule ".my-1" [ marginTop (lengthRaw "0.25rem") , marginBottom (lengthRaw "0.25rem") ]
    , rule ".my-2" [ marginTop (lengthRaw "0.5rem") , marginBottom (lengthRaw "0.5rem") ]
    , rule ".my-3" [ marginTop (lengthRaw "0.75rem") , marginBottom (lengthRaw "0.75rem") ]
    , rule ".my-4" [ marginTop (lengthRaw "1rem") , marginBottom (lengthRaw "1rem") ]
    , rule ".my-5" [ marginTop (lengthRaw "1.25rem") , marginBottom (lengthRaw "1.25rem") ]
    , rule ".my-6" [ marginTop (lengthRaw "1.5rem") , marginBottom (lengthRaw "1.5rem") ]
    , rule ".my-8" [ marginTop (lengthRaw "2rem") , marginBottom (lengthRaw "2rem") ]
    , rule ".my-10" [ marginTop (lengthRaw "2.5rem") , marginBottom (lengthRaw "2.5rem") ]
    , rule ".my-12" [ marginTop (lengthRaw "3rem") , marginBottom (lengthRaw "3rem") ]
    , rule ".mt-0" [ marginTop (lengthRaw "0") ]
    , rule ".mt-1" [ marginTop (lengthRaw "0.25rem") ]
    , rule ".mt-2" [ marginTop (lengthRaw "0.5rem") ]
    , rule ".mt-3" [ marginTop (lengthRaw "0.75rem") ]
    , rule ".mt-4" [ marginTop (lengthRaw "1rem") ]
    , rule ".mt-5" [ marginTop (lengthRaw "1.25rem") ]
    , rule ".mt-6" [ marginTop (lengthRaw "1.5rem") ]
    , rule ".mt-8" [ marginTop (lengthRaw "2rem") ]
    , rule ".mt-10" [ marginTop (lengthRaw "2.5rem") ]
    , rule ".mt-12" [ marginTop (lengthRaw "3rem") ]
    , rule ".mt-16" [ marginTop (lengthRaw "4rem") ]
    , rule ".mt-20" [ marginTop (lengthRaw "5rem") ]
    , rule ".mt-24" [ marginTop (lengthRaw "6rem") ]
    , rule ".mt-auto" [ marginTop (lengthRaw "auto") ]
    , rule ".-mt-1" [ marginTop (lengthRaw "-0.25rem") ]
    , rule ".-mt-2" [ marginTop (lengthRaw "-0.5rem") ]
    , rule ".-mt-4" [ marginTop (lengthRaw "-1rem") ]
    , rule ".-mt-8" [ marginTop (lengthRaw "-2rem") ]
    , rule ".mr-0" [ marginRight (lengthRaw "0") ]
    , rule ".mr-1" [ marginRight (lengthRaw "0.25rem") ]
    , rule ".mr-2" [ marginRight (lengthRaw "0.5rem") ]
    , rule ".mr-3" [ marginRight (lengthRaw "0.75rem") ]
    , rule ".mr-4" [ marginRight (lengthRaw "1rem") ]
    , rule ".mr-5" [ marginRight (lengthRaw "1.25rem") ]
    , rule ".mr-6" [ marginRight (lengthRaw "1.5rem") ]
    , rule ".mr-8" [ marginRight (lengthRaw "2rem") ]
    , rule ".mr-auto" [ marginRight (lengthRaw "auto") ]
    , rule ".mb-0" [ marginBottom (lengthRaw "0") ]
    , rule ".mb-1" [ marginBottom (lengthRaw "0.25rem") ]
    , rule ".mb-2" [ marginBottom (lengthRaw "0.5rem") ]
    , rule ".mb-3" [ marginBottom (lengthRaw "0.75rem") ]
    , rule ".mb-4" [ marginBottom (lengthRaw "1rem") ]
    , rule ".mb-5" [ marginBottom (lengthRaw "1.25rem") ]
    , rule ".mb-6" [ marginBottom (lengthRaw "1.5rem") ]
    , rule ".mb-8" [ marginBottom (lengthRaw "2rem") ]
    , rule ".mb-10" [ marginBottom (lengthRaw "2.5rem") ]
    , rule ".mb-12" [ marginBottom (lengthRaw "3rem") ]
    , rule ".mb-16" [ marginBottom (lengthRaw "4rem") ]
    , rule ".mb-20" [ marginBottom (lengthRaw "5rem") ]
    , rule ".mb-24" [ marginBottom (lengthRaw "6rem") ]
    , rule ".ml-0" [ marginLeft (lengthRaw "0") ]
    , rule ".ml-1" [ marginLeft (lengthRaw "0.25rem") ]
    , rule ".ml-2" [ marginLeft (lengthRaw "0.5rem") ]
    , rule ".ml-3" [ marginLeft (lengthRaw "0.75rem") ]
    , rule ".ml-4" [ marginLeft (lengthRaw "1rem") ]
    , rule ".ml-5" [ marginLeft (lengthRaw "1.25rem") ]
    , rule ".ml-6" [ marginLeft (lengthRaw "1.5rem") ]
    , rule ".ml-8" [ marginLeft (lengthRaw "2rem") ]
    , rule ".ml-auto" [ marginLeft (lengthRaw "auto") ]
    , rule ".-mb-1" [ marginBottom (lengthRaw "-0.25rem") ]
    , rule ".-mb-2" [ marginBottom (lengthRaw "-0.5rem") ]
    , rule ".-ml-1" [ marginLeft (lengthRaw "-0.25rem") ]
    , rule ".-ml-2" [ marginLeft (lengthRaw "-0.5rem") ]
    , rule ".-mr-1" [ marginRight (lengthRaw "-0.25rem") ]
    , rule ".-mr-2" [ marginRight (lengthRaw "-0.5rem") ]
    , rule ".-mx-4" [ marginLeft (lengthRaw "-1rem") , marginRight (lengthRaw "-1rem") ]
    , rule ".gap-0" [ gap (lengthRaw "0") ]
    , rule ".gap-1" [ gap (lengthRaw "0.25rem") ]
    , rule ".gap-2" [ gap (lengthRaw "0.5rem") ]
    , rule ".gap-3" [ gap (lengthRaw "0.75rem") ]
    , rule ".gap-4" [ gap (lengthRaw "1rem") ]
    , rule ".gap-5" [ gap (lengthRaw "1.25rem") ]
    , rule ".gap-6" [ gap (lengthRaw "1.5rem") ]
    , rule ".gap-8" [ gap (lengthRaw "2rem") ]
    , rule ".gap-10" [ gap (lengthRaw "2.5rem") ]
    , rule ".gap-12" [ gap (lengthRaw "3rem") ]
    , rule ".gap-16" [ gap (lengthRaw "4rem") ]
    , rule ".gap-20" [ gap (lengthRaw "5rem") ]
    , rule ".gap-24" [ gap (lengthRaw "6rem") ]
    , rule ".gap-x-0" [ property "column-gap" "0" ]
    , rule ".gap-x-1" [ property "column-gap" "0.25rem" ]
    , rule ".gap-x-2" [ property "column-gap" "0.5rem" ]
    , rule ".gap-x-3" [ property "column-gap" "0.75rem" ]
    , rule ".gap-x-4" [ property "column-gap" "1rem" ]
    , rule ".gap-x-6" [ property "column-gap" "1.5rem" ]
    , rule ".gap-x-8" [ property "column-gap" "2rem" ]
    , rule ".gap-y-0" [ property "row-gap" "0" ]
    , rule ".gap-y-1" [ property "row-gap" "0.25rem" ]
    , rule ".gap-y-2" [ property "row-gap" "0.5rem" ]
    , rule ".gap-y-3" [ property "row-gap" "0.75rem" ]
    , rule ".gap-y-4" [ property "row-gap" "1rem" ]
    , rule ".gap-y-6" [ property "row-gap" "1.5rem" ]
    , rule ".gap-y-8" [ property "row-gap" "2rem" ]
    , rule ".space-x-0 > * + *" [ marginLeft (lengthRaw "0") ]
    , rule ".space-x-1 > * + *" [ marginLeft (lengthRaw "0.25rem") ]
    , rule ".space-x-2 > * + *" [ marginLeft (lengthRaw "0.5rem") ]
    , rule ".space-x-3 > * + *" [ marginLeft (lengthRaw "0.75rem") ]
    , rule ".space-x-4 > * + *" [ marginLeft (lengthRaw "1rem") ]
    , rule ".space-x-6 > * + *" [ marginLeft (lengthRaw "1.5rem") ]
    , rule ".space-x-8 > * + *" [ marginLeft (lengthRaw "2rem") ]
