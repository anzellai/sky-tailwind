    , rule ".my-6" [ marginTop "1.5rem" , marginBottom "1.5rem" ]
    , rule ".my-8" [ marginTop "2rem" , marginBottom "2rem" ]
    , rule ".my-10" [ marginTop "2.5rem" , marginBottom "2.5rem" ]
    , rule ".my-12" [ marginTop "3rem" , marginBottom "3rem" ]
    , rule ".mt-0" [ marginTop "0" ]
    , rule ".mt-1" [ marginTop "0.25rem" ]
    , rule ".mt-2" [ marginTop "0.5rem" ]
    , rule ".mt-3" [ marginTop "0.75rem" ]
    , rule ".mt-4" [ marginTop "1rem" ]
    , rule ".mt-5" [ marginTop "1.25rem" ]
    , rule ".mt-6" [ marginTop "1.5rem" ]
    , rule ".mt-8" [ marginTop "2rem" ]
    , rule ".mt-10" [ marginTop "2.5rem" ]
    , rule ".mt-12" [ marginTop "3rem" ]
    , rule ".mt-16" [ marginTop "4rem" ]
    , rule ".mt-20" [ marginTop "5rem" ]
    , rule ".mt-24" [ marginTop "6rem" ]
    , rule ".mt-auto" [ marginTop "auto" ]
    , rule ".-mt-1" [ marginTop "-0.25rem" ]
    , rule ".-mt-2" [ marginTop "-0.5rem" ]
    , rule ".-mt-4" [ marginTop "-1rem" ]
    , rule ".-mt-8" [ marginTop "-2rem" ]
    , rule ".mr-0" [ marginRight "0" ]
    , rule ".mr-1" [ marginRight "0.25rem" ]
    , rule ".mr-2" [ marginRight "0.5rem" ]
    , rule ".mr-3" [ marginRight "0.75rem" ]
