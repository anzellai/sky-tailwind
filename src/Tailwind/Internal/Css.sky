-- ============================================================
-- Layout: display, position, z-index, overflow, float, clear, visibility, isolation
-- ============================================================
layoutRules =
    [ rule ".block" [ display "block" ]

    -- Position
    , rule ".inline-block" [ display "inline-block" ]

    -- Inset (top/right/bottom/left)
    , rule ".inline" [ display "inline" ]

    -- Z-Index
    , rule ".flex" [ display "flex" ]

    -- Overflow
    , rule ".inline-flex" [ display "inline-flex" ]

    -- Overscroll
    , rule ".grid" [ display "grid" ]

    -- Float
    , rule ".inline-grid" [ display "inline-grid" ]

    -- Clear
    , rule ".hidden" [ display "none" ]

    -- Visibility
    , rule ".contents" [ display "contents" ]

    -- Isolation
    , rule ".flow-root" [ display "flow-root" ]

    -- Columns
    , rule ".table" [ display "table" ]

    -- Break
    , rule ".table-caption" [ display "table-caption" ]
    , rule ".table-row" [ display "table-row" ]
    , rule ".table-cell" [ display "table-cell" ]
    , rule ".table-column" [ display "table-column" ]
    , rule ".table-column-group" [ display "table-column-group" ]
    , rule ".table-footer-group" [ display "table-footer-group" ]
    , rule ".table-header-group" [ display "table-header-group" ]
    , rule ".table-row-group" [ display "table-row-group" ]
    , rule ".static" [ position "static" ]
    , rule ".relative" [ position "relative" ]
    , rule ".absolute" [ position "absolute" ]
    , rule ".fixed" [ position "fixed" ]
    , rule ".sticky" [ position "sticky" ]
    , rule ".inset-0" [ top "0" , right_ "0" , bottom "0" , left "0" ]
    , rule ".inset-1"
        [ top "0.25rem" , right_ "0.25rem" , bottom "0.25rem" , left "0.25rem" ]
    , rule ".inset-2"
        [ top "0.5rem" , right_ "0.5rem" , bottom "0.5rem" , left "0.5rem" ]
    , rule ".inset-4"
        [ top "1rem" , right_ "1rem" , bottom "1rem" , left "1rem" ]
    , rule ".inset-auto"
        [ top "auto" , right_ "auto" , bottom "auto" , left "auto" ]
    , rule ".inset-x-0" [ left "0" , right_ "0" ]
    , rule ".inset-x-auto" [ left "auto" , right_ "auto" ]
    , rule ".inset-y-0" [ top "0" , bottom "0" ]
    , rule ".inset-y-auto" [ top "auto" , bottom "auto" ]
    , rule ".top-0" [ top "0" ]
    , rule ".top-1" [ top "0.25rem" ]
    , rule ".top-2" [ top "0.5rem" ]
    , rule ".top-3" [ top "0.75rem" ]
    , rule ".top-4" [ top "1rem" ]
    , rule ".top-6" [ top "1.5rem" ]
    , rule ".top-8" [ top "2rem" ]
    , rule ".top-12" [ top "3rem" ]
    , rule ".top-16" [ top "4rem" ]
    , rule ".top-auto" [ top "auto" ]
    , rule ".top-full" [ top "100%" ]
    , rule ".top-1\\/2" [ top "50%" ]
    , rule ".-top-1" [ top "-0.25rem" ]
    , rule ".-top-2" [ top "-0.5rem" ]
    , rule ".-top-4" [ top "-1rem" ]
    , rule ".right-0" [ right_ "0" ]
    , rule ".right-1" [ right_ "0.25rem" ]
    , rule ".right-2" [ right_ "0.5rem" ]
    , rule ".right-4" [ right_ "1rem" ]
    , rule ".right-6" [ right_ "1.5rem" ]
    , rule ".right-8" [ right_ "2rem" ]
    , rule ".right-auto" [ right_ "auto" ]
    , rule ".bottom-0" [ bottom "0" ]
    , rule ".bottom-1" [ bottom "0.25rem" ]
    , rule ".bottom-2" [ bottom "0.5rem" ]
    , rule ".bottom-4" [ bottom "1rem" ]
    , rule ".bottom-6" [ bottom "1.5rem" ]
    , rule ".bottom-8" [ bottom "2rem" ]
    , rule ".bottom-auto" [ bottom "auto" ]
    , rule ".left-0" [ left "0" ]
    , rule ".left-1" [ left "0.25rem" ]
    , rule ".left-2" [ left "0.5rem" ]
    , rule ".left-4" [ left "1rem" ]
    , rule ".left-6" [ left "1.5rem" ]
    , rule ".left-8" [ left "2rem" ]
    , rule ".left-auto" [ left "auto" ]
    , rule ".left-full" [ left "100%" ]
    , rule ".left-1\\/2" [ left "50%" ]
    , rule ".z-0" [ property "z-index" "0" ]
    , rule ".z-10" [ property "z-index" "10" ]
    , rule ".z-20" [ property "z-index" "20" ]
    , rule ".z-30" [ property "z-index" "30" ]
    , rule ".z-40" [ property "z-index" "40" ]
    , rule ".z-50" [ property "z-index" "50" ]
    , rule ".z-auto" [ property "z-index" "auto" ]
    , rule ".-z-10" [ property "z-index" "-10" ]
    , rule ".overflow-auto" [ overflow "auto" ]
    , rule ".overflow-hidden" [ overflow "hidden" ]
    , rule ".overflow-clip" [ overflow "clip" ]
    , rule ".overflow-visible" [ overflow "visible" ]
    , rule ".overflow-scroll" [ overflow "scroll" ]
    , rule ".overflow-x-auto" [ property "overflow-x" "auto" ]
    , rule ".overflow-x-hidden" [ property "overflow-x" "hidden" ]
    , rule ".overflow-x-clip" [ property "overflow-x" "clip" ]
    , rule ".overflow-x-scroll" [ property "overflow-x" "scroll" ]
    , rule ".overflow-y-auto" [ property "overflow-y" "auto" ]
    , rule ".overflow-y-hidden" [ property "overflow-y" "hidden" ]
    , rule ".overflow-y-clip" [ property "overflow-y" "clip" ]
    , rule ".overflow-y-scroll" [ property "overflow-y" "scroll" ]
    , rule ".overscroll-auto" [ property "overscroll-behavior" "auto" ]
    , rule ".overscroll-contain" [ property "overscroll-behavior" "contain" ]
    , rule ".overscroll-none" [ property "overscroll-behavior" "none" ]
    , rule ".float-left" [ float "left" ]
    , rule ".float-right" [ float "right" ]
    , rule ".float-none" [ float "none" ]
    , rule ".clear-left" [ clear "left" ]
    , rule ".clear-right" [ clear "right" ]
    , rule ".clear-both" [ clear "both" ]
    , rule ".clear-none" [ clear "none" ]
    , rule ".visible" [ visibility "visible" ]
    , rule ".invisible" [ visibility "hidden" ]
    , rule ".collapse" [ visibility "collapse" ]
    , rule ".isolate" [ property "isolation" "isolate" ]
    , rule ".isolation-auto" [ property "isolation" "auto" ]
    , rule ".columns-1" [ property "columns" "1" ]
    , rule ".columns-2" [ property "columns" "2" ]
    , rule ".columns-3" [ property "columns" "3" ]
    , rule ".columns-4" [ property "columns" "4" ]
    , rule ".columns-auto" [ property "columns" "auto" ]
    , rule ".break-after-auto" [ property "break-after" "auto" ]
    , rule ".break-after-avoid" [ property "break-after" "avoid" ]
    , rule ".break-before-auto" [ property "break-before" "auto" ]
    , rule ".break-before-avoid" [ property "break-before" "avoid" ]
    , rule ".break-inside-auto" [ property "break-inside" "auto" ]
    , rule ".break-inside-avoid" [ property "break-inside" "avoid" ]
    ]

-- ============================================================
-- Flexbox
-- ============================================================
flexRules =
    [ rule ".flex-row" [ flexDirection "row" ]

    -- Flex Wrap
    , rule ".flex-row-reverse" [ flexDirection "row-reverse" ]

    -- Justify Content
    , rule ".flex-col" [ flexDirection "column" ]

    -- Justify Items
    , rule ".flex-col-reverse" [ flexDirection "column-reverse" ]

    -- Justify Self
    , rule ".flex-wrap" [ flexWrap "wrap" ]

    -- Align Items
    , rule ".flex-wrap-reverse" [ flexWrap "wrap-reverse" ]

    -- Align Self
    , rule ".flex-nowrap" [ flexWrap "nowrap" ]

    -- Align Content
    , rule ".justify-start" [ justifyContent "flex-start" ]

    -- Flex shorthand
    , rule ".justify-end" [ justifyContent "flex-end" ]

    -- Flex Grow
    , rule ".justify-center" [ justifyContent "center" ]

    -- Flex Shrink
    , rule ".justify-between" [ justifyContent "space-between" ]

    -- Flex Basis
    , rule ".justify-around" [ justifyContent "space-around" ]

    -- Order
    , rule ".justify-evenly" [ justifyContent "space-evenly" ]
    , rule ".justify-stretch" [ justifyContent "stretch" ]
    , rule ".justify-normal" [ justifyContent "normal" ]
    , rule ".justify-items-start" [ property "justify-items" "start" ]
    , rule ".justify-items-end" [ property "justify-items" "end" ]
    , rule ".justify-items-center" [ property "justify-items" "center" ]
    , rule ".justify-items-stretch" [ property "justify-items" "stretch" ]
    , rule ".justify-self-auto" [ property "justify-self" "auto" ]
    , rule ".justify-self-start" [ property "justify-self" "start" ]
    , rule ".justify-self-end" [ property "justify-self" "end" ]
    , rule ".justify-self-center" [ property "justify-self" "center" ]
    , rule ".justify-self-stretch" [ property "justify-self" "stretch" ]
    , rule ".items-start" [ alignItems "flex-start" ]
    , rule ".items-end" [ alignItems "flex-end" ]
    , rule ".items-center" [ alignItems "center" ]
    , rule ".items-baseline" [ alignItems "baseline" ]
    , rule ".items-stretch" [ alignItems "stretch" ]
    , rule ".self-auto" [ property "align-self" "auto" ]
    , rule ".self-start" [ property "align-self" "flex-start" ]
    , rule ".self-end" [ property "align-self" "flex-end" ]
    , rule ".self-center" [ property "align-self" "center" ]
    , rule ".self-stretch" [ property "align-self" "stretch" ]
    , rule ".self-baseline" [ property "align-self" "baseline" ]
    , rule ".content-start" [ alignContent "flex-start" ]
    , rule ".content-end" [ alignContent "flex-end" ]
    , rule ".content-center" [ alignContent "center" ]
    , rule ".content-between" [ alignContent "space-between" ]
    , rule ".content-around" [ alignContent "space-around" ]
    , rule ".content-evenly" [ alignContent "space-evenly" ]
    , rule ".content-baseline" [ alignContent "baseline" ]
    , rule ".content-normal" [ alignContent "normal" ]
    , rule ".flex-1" [ flex "1 1 0%" ]
    , rule ".flex-auto" [ flex "1 1 auto" ]
    , rule ".flex-initial" [ flex "0 1 auto" ]
    , rule ".flex-none" [ flex "none" ]
    , rule ".grow" [ property "flex-grow" "1" ]
    , rule ".grow-0" [ property "flex-grow" "0" ]
    , rule ".shrink" [ property "flex-shrink" "1" ]
    , rule ".shrink-0" [ property "flex-shrink" "0" ]
    , rule ".basis-0" [ property "flex-basis" "0" ]
    , rule ".basis-1" [ property "flex-basis" "0.25rem" ]
    , rule ".basis-2" [ property "flex-basis" "0.5rem" ]
    , rule ".basis-4" [ property "flex-basis" "1rem" ]
    , rule ".basis-8" [ property "flex-basis" "2rem" ]
    , rule ".basis-12" [ property "flex-basis" "3rem" ]
    , rule ".basis-16" [ property "flex-basis" "4rem" ]
    , rule ".basis-24" [ property "flex-basis" "6rem" ]
    , rule ".basis-32" [ property "flex-basis" "8rem" ]
    , rule ".basis-auto" [ property "flex-basis" "auto" ]
    , rule ".basis-full" [ property "flex-basis" "100%" ]
    , rule ".basis-1\\/2" [ property "flex-basis" "50%" ]
    , rule ".basis-1\\/3" [ property "flex-basis" "33.333333%" ]
    , rule ".basis-2\\/3" [ property "flex-basis" "66.666667%" ]
    , rule ".basis-1\\/4" [ property "flex-basis" "25%" ]
    , rule ".basis-3\\/4" [ property "flex-basis" "75%" ]
    , rule ".order-1" [ property "order" "1" ]
    , rule ".order-2" [ property "order" "2" ]
    , rule ".order-3" [ property "order" "3" ]
    , rule ".order-4" [ property "order" "4" ]
    , rule ".order-5" [ property "order" "5" ]
    , rule ".order-6" [ property "order" "6" ]
    , rule ".order-7" [ property "order" "7" ]
    , rule ".order-8" [ property "order" "8" ]
    , rule ".order-9" [ property "order" "9" ]
    , rule ".order-10" [ property "order" "10" ]
    , rule ".order-11" [ property "order" "11" ]
    , rule ".order-12" [ property "order" "12" ]
    , rule ".order-first" [ property "order" "-9999" ]
    , rule ".order-last" [ property "order" "9999" ]
    , rule ".order-none" [ property "order" "0" ]
    ]

-- ============================================================
-- Grid
-- ============================================================
gridRules =
    [ rule ".grid-cols-1" [ gridTemplateColumns "repeat(1, minmax(0, 1fr))" ]

    -- Grid Template Rows
    , rule ".grid-cols-2" [ gridTemplateColumns "repeat(2, minmax(0, 1fr))" ]

    -- Column Span
    , rule ".grid-cols-3" [ gridTemplateColumns "repeat(3, minmax(0, 1fr))" ]

    -- Row Span
    , rule ".grid-cols-4" [ gridTemplateColumns "repeat(4, minmax(0, 1fr))" ]

    -- Grid Auto Flow
    , rule ".grid-cols-5" [ gridTemplateColumns "repeat(5, minmax(0, 1fr))" ]

    -- Grid Auto Columns
    , rule ".grid-cols-6" [ gridTemplateColumns "repeat(6, minmax(0, 1fr))" ]

    -- Grid Auto Rows
    , rule ".grid-cols-7" [ gridTemplateColumns "repeat(7, minmax(0, 1fr))" ]

    -- Place Content
    , rule ".grid-cols-8" [ gridTemplateColumns "repeat(8, minmax(0, 1fr))" ]

    -- Place Items
    , rule ".grid-cols-9" [ gridTemplateColumns "repeat(9, minmax(0, 1fr))" ]

    -- Place Self
    , rule ".grid-cols-10" [ gridTemplateColumns "repeat(10, minmax(0, 1fr))" ]
    , rule ".grid-cols-11" [ gridTemplateColumns "repeat(11, minmax(0, 1fr))" ]
    , rule ".grid-cols-12" [ gridTemplateColumns "repeat(12, minmax(0, 1fr))" ]
    , rule ".grid-cols-none" [ gridTemplateColumns "none" ]
    , rule ".grid-cols-subgrid" [ gridTemplateColumns "subgrid" ]
    , rule ".grid-rows-1" [ gridTemplateRows "repeat(1, minmax(0, 1fr))" ]
    , rule ".grid-rows-2" [ gridTemplateRows "repeat(2, minmax(0, 1fr))" ]
    , rule ".grid-rows-3" [ gridTemplateRows "repeat(3, minmax(0, 1fr))" ]
    , rule ".grid-rows-4" [ gridTemplateRows "repeat(4, minmax(0, 1fr))" ]
    , rule ".grid-rows-5" [ gridTemplateRows "repeat(5, minmax(0, 1fr))" ]
    , rule ".grid-rows-6" [ gridTemplateRows "repeat(6, minmax(0, 1fr))" ]
    , rule ".grid-rows-none" [ gridTemplateRows "none" ]
    , rule ".grid-rows-subgrid" [ gridTemplateRows "subgrid" ]
    , rule ".col-auto" [ gridColumn "auto" ]
