-- ============================================================
-- Effects: shadow, opacity, transition, mix-blend
-- ============================================================
effectsRules =
    [ rule ".shadow-sm" [ boxShadow "0 1px 2px 0 rgba(0, 0, 0, 0.05)" ]

    -- Opacity
    , rule ".shadow"
        [ boxShadow
            "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)"
        ]

    -- Mix Blend Mode
    , rule ".shadow-md"
        [ boxShadow
            "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
        ]

    -- Transition
    , rule ".shadow-lg"
        [ boxShadow
            "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
        ]

    -- Transition Duration
    , rule ".shadow-xl"
        [ boxShadow
            "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
        ]

    -- Transition Timing Function
    , rule ".shadow-2xl" [ boxShadow "0 25px 50px -12px rgba(0, 0, 0, 0.25)" ]

    -- Transition Delay
    , rule ".shadow-inner" [ boxShadow "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)" ]

    -- Will Change
    , rule ".shadow-none" [ boxShadow "none" ]
    , rule ".opacity-0" [ property "opacity" "0" ]
    , rule ".opacity-5" [ property "opacity" "0.05" ]
    , rule ".opacity-10" [ property "opacity" "0.1" ]
    , rule ".opacity-15" [ property "opacity" "0.15" ]
    , rule ".opacity-20" [ property "opacity" "0.2" ]
    , rule ".opacity-25" [ property "opacity" "0.25" ]
    , rule ".opacity-30" [ property "opacity" "0.3" ]
    , rule ".opacity-40" [ property "opacity" "0.4" ]
    , rule ".opacity-50" [ property "opacity" "0.5" ]
    , rule ".opacity-60" [ property "opacity" "0.6" ]
    , rule ".opacity-70" [ property "opacity" "0.7" ]
    , rule ".opacity-75" [ property "opacity" "0.75" ]
    , rule ".opacity-80" [ property "opacity" "0.8" ]
    , rule ".opacity-90" [ property "opacity" "0.9" ]
    , rule ".opacity-95" [ property "opacity" "0.95" ]
    , rule ".opacity-100" [ property "opacity" "1" ]
    , rule ".mix-blend-normal" [ property "mix-blend-mode" "normal" ]
    , rule ".mix-blend-multiply" [ property "mix-blend-mode" "multiply" ]
    , rule ".mix-blend-screen" [ property "mix-blend-mode" "screen" ]
    , rule ".mix-blend-overlay" [ property "mix-blend-mode" "overlay" ]
    , rule ".mix-blend-darken" [ property "mix-blend-mode" "darken" ]
    , rule ".mix-blend-lighten" [ property "mix-blend-mode" "lighten" ]
    , rule ".mix-blend-color-dodge" [ property "mix-blend-mode" "color-dodge" ]
    , rule ".mix-blend-color-burn" [ property "mix-blend-mode" "color-burn" ]
    , rule ".mix-blend-hard-light" [ property "mix-blend-mode" "hard-light" ]
    , rule ".mix-blend-soft-light" [ property "mix-blend-mode" "soft-light" ]
    , rule ".mix-blend-difference" [ property "mix-blend-mode" "difference" ]
    , rule ".mix-blend-exclusion" [ property "mix-blend-mode" "exclusion" ]
    , rule ".transition-all"
        [ transition "all 150ms cubic-bezier(0.4, 0, 0.2, 1)" ]
    , rule ".transition"
        [ transition
            "color, background-color, border-color, text-decoration-color, fill, stroke, opacity, box-shadow, transform, filter, backdrop-filter 150ms cubic-bezier(0.4, 0, 0.2, 1)"
        ]
    , rule ".transition-colors"
        [ transition
            "color, background-color, border-color, text-decoration-color, fill, stroke 150ms cubic-bezier(0.4, 0, 0.2, 1)"
        ]
    , rule ".transition-opacity"
        [ transition "opacity 150ms cubic-bezier(0.4, 0, 0.2, 1)" ]
    , rule ".transition-shadow"
        [ transition "box-shadow 150ms cubic-bezier(0.4, 0, 0.2, 1)" ]
    , rule ".transition-transform"
        [ transition "transform 150ms cubic-bezier(0.4, 0, 0.2, 1)" ]
    , rule ".transition-none" [ transition "none" ]
    , rule ".duration-75" [ property "transition-duration" "75ms" ]
    , rule ".duration-100" [ property "transition-duration" "100ms" ]
    , rule ".duration-150" [ property "transition-duration" "150ms" ]
    , rule ".duration-200" [ property "transition-duration" "200ms" ]
    , rule ".duration-300" [ property "transition-duration" "300ms" ]
    , rule ".duration-500" [ property "transition-duration" "500ms" ]
    , rule ".duration-700" [ property "transition-duration" "700ms" ]
    , rule ".duration-1000" [ property "transition-duration" "1000ms" ]
    , rule ".ease-linear" [ property "transition-timing-function" "linear" ]
    , rule ".ease-in"
        [ property "transition-timing-function" "cubic-bezier(0.4, 0, 1, 1)" ]
    , rule ".ease-out"
        [ property "transition-timing-function" "cubic-bezier(0, 0, 0.2, 1)" ]
    , rule ".ease-in-out"
        [ property "transition-timing-function" "cubic-bezier(0.4, 0, 0.2, 1)" ]
    , rule ".delay-75" [ property "transition-delay" "75ms" ]
    , rule ".delay-100" [ property "transition-delay" "100ms" ]
    , rule ".delay-150" [ property "transition-delay" "150ms" ]
    , rule ".delay-200" [ property "transition-delay" "200ms" ]
    , rule ".delay-300" [ property "transition-delay" "300ms" ]
    , rule ".delay-500" [ property "transition-delay" "500ms" ]
    , rule ".delay-700" [ property "transition-delay" "700ms" ]
    , rule ".delay-1000" [ property "transition-delay" "1000ms" ]
    , rule ".will-change-auto" [ property "will-change" "auto" ]
    , rule ".will-change-scroll" [ property "will-change" "scroll-position" ]
    , rule ".will-change-contents" [ property "will-change" "contents" ]
    , rule ".will-change-transform" [ property "will-change" "transform" ]
    ]

-- ============================================================
-- Sizing: width, height, min/max, aspect-ratio, object, box, container
-- ============================================================
sizingRules =
    [ rule ".w-0" [ width (lengthRaw "0") ]

    -- Height
    , rule ".w-1" [ width (lengthRaw "0.25rem") ]

