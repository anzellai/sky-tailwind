-- ============================================================
-- SVG
-- ============================================================
svgRules =
    [ rule ".fill-current" [ property "fill" "currentColor" ]
    , rule ".fill-none" [ property "fill" "none" ]
    , rule ".fill-black" [ property "fill" "#000000" ]
    , rule ".fill-white" [ property "fill" "#ffffff" ]
    , rule ".fill-red-500" [ property "fill" "#ef4444" ]
    , rule ".fill-blue-500" [ property "fill" "#3b82f6" ]
    , rule ".fill-green-500" [ property "fill" "#22c55e" ]
    , rule ".fill-gray-500" [ property "fill" "#6b7280" ]
    , rule ".stroke-current" [ property "stroke" "currentColor" ]
    , rule ".stroke-none" [ property "stroke" "none" ]
    , rule ".stroke-black" [ property "stroke" "#000000" ]
    , rule ".stroke-white" [ property "stroke" "#ffffff" ]
    , rule ".stroke-gray-300" [ property "stroke" "#d1d5db" ]
    , rule ".stroke-gray-500" [ property "stroke" "#6b7280" ]
    , rule ".stroke-blue-500" [ property "stroke" "#3b82f6" ]
    , rule ".stroke-0" [ property "stroke-width" "0" ]
    , rule ".stroke-1" [ property "stroke-width" "1" ]
    , rule ".stroke-2" [ property "stroke-width" "2" ]
    ]

-- ============================================================
-- Interactivity: cursor, pointer-events, user-select, resize, scroll, touch, appearance
-- ============================================================
interactivityRules =
    [ rule ".cursor-auto" [ cursor "auto" ]

    -- Pointer Events
    , rule ".cursor-default" [ cursor "default" ]

    -- User Select
    , rule ".cursor-pointer" [ cursor "pointer" ]

    -- Resize
    , rule ".cursor-wait" [ cursor "wait" ]

    -- Scroll Behavior
    , rule ".cursor-text" [ cursor "text" ]

    -- Scroll Snap Type
    , rule ".cursor-move" [ cursor "move" ]

    -- Scroll Snap Align
    , rule ".cursor-help" [ cursor "help" ]

    -- Scroll Margin
    , rule ".cursor-not-allowed" [ cursor "not-allowed" ]

    -- Scroll Padding
    , rule ".cursor-none" [ cursor "none" ]

    -- Touch Action
    , rule ".cursor-context-menu" [ cursor "context-menu" ]

    -- Appearance
    , rule ".cursor-progress" [ cursor "progress" ]

    -- Caret Color
    , rule ".cursor-cell" [ cursor "cell" ]

    -- Accent Color
    , rule ".cursor-crosshair" [ cursor "crosshair" ]
    , rule ".cursor-vertical-text" [ cursor "vertical-text" ]
    , rule ".cursor-alias" [ cursor "alias" ]
    , rule ".cursor-copy" [ cursor "copy" ]
    , rule ".cursor-no-drop" [ cursor "no-drop" ]
    , rule ".cursor-grab" [ cursor "grab" ]
    , rule ".cursor-grabbing" [ cursor "grabbing" ]
    , rule ".cursor-all-scroll" [ cursor "all-scroll" ]
    , rule ".cursor-col-resize" [ cursor "col-resize" ]
    , rule ".cursor-row-resize" [ cursor "row-resize" ]
    , rule ".cursor-zoom-in" [ cursor "zoom-in" ]
    , rule ".cursor-zoom-out" [ cursor "zoom-out" ]
    , rule ".pointer-events-none" [ property "pointer-events" "none" ]
    , rule ".pointer-events-auto" [ property "pointer-events" "auto" ]
    , rule ".select-none" [ property "user-select" "none" ]
    , rule ".select-text" [ property "user-select" "text" ]
    , rule ".select-all" [ property "user-select" "all" ]
    , rule ".select-auto" [ property "user-select" "auto" ]
    , rule ".resize-none" [ property "resize" "none" ]
    , rule ".resize-y" [ property "resize" "vertical" ]
    , rule ".resize-x" [ property "resize" "horizontal" ]
    , rule ".resize" [ property "resize" "both" ]
    , rule ".scroll-auto" [ property "scroll-behavior" "auto" ]
    , rule ".scroll-smooth" [ property "scroll-behavior" "smooth" ]
    , rule ".snap-none" [ property "scroll-snap-type" "none" ]
    , rule ".snap-x" [ property "scroll-snap-type" "x mandatory" ]
    , rule ".snap-y" [ property "scroll-snap-type" "y mandatory" ]
    , rule ".snap-both" [ property "scroll-snap-type" "both mandatory" ]
    , rule ".snap-start" [ property "scroll-snap-align" "start" ]
