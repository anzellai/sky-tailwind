    , rule ".space-y-1 > * + *" [ marginTop (lengthRaw "0.25rem") ]
    , rule ".space-y-2 > * + *" [ marginTop (lengthRaw "0.5rem") ]
    , rule ".space-y-3 > * + *" [ marginTop (lengthRaw "0.75rem") ]
    , rule ".space-y-4 > * + *" [ marginTop (lengthRaw "1rem") ]
    , rule ".space-y-6 > * + *" [ marginTop (lengthRaw "1.5rem") ]
    , rule ".space-y-8 > * + *" [ marginTop (lengthRaw "2rem") ]
