-- ============================================================
-- Typography
-- ============================================================
typographyRules =
    [ rule ".text-xs" [ fontSize "0.75rem" , lineHeight "1rem" ]

    -- Font Weight
    , rule ".text-sm" [ fontSize "0.875rem" , lineHeight "1.25rem" ]

    -- Font Family
    , rule ".text-base" [ fontSize "1rem" , lineHeight "1.5rem" ]

    -- Text Align
    , rule ".text-lg" [ fontSize "1.125rem" , lineHeight "1.75rem" ]

    -- Text Color: black/white/transparent
    , rule ".text-xl" [ fontSize "1.25rem" , lineHeight "1.75rem" ]

    -- Text Color: slate
    , rule ".text-2xl" [ fontSize "1.5rem" , lineHeight "2rem" ]

    -- Text Color: gray
    , rule ".text-3xl" [ fontSize "1.875rem" , lineHeight "2.25rem" ]

    -- Text Color: red
    , rule ".text-4xl" [ fontSize "2.25rem" , lineHeight "2.5rem" ]

    -- Text Color: orange
    , rule ".text-5xl" [ fontSize "3rem" , lineHeight "1" ]

    -- Text Color: amber
    , rule ".text-6xl" [ fontSize "3.75rem" , lineHeight "1" ]

    -- Text Color: yellow
    , rule ".text-7xl" [ fontSize "4.5rem" , lineHeight "1" ]

    -- Text Color: lime
    , rule ".text-8xl" [ fontSize "6rem" , lineHeight "1" ]

    -- Text Color: green
    , rule ".text-9xl" [ fontSize "8rem" , lineHeight "1" ]

    -- Text Color: emerald
    , rule ".font-thin" [ fontWeight "100" ]

    -- Text Color: teal
    , rule ".font-extralight" [ fontWeight "200" ]

    -- Text Color: cyan
    , rule ".font-light" [ fontWeight "300" ]

    -- Text Color: sky
    , rule ".font-normal" [ fontWeight "400" ]

    -- Text Color: blue
    , rule ".font-medium" [ fontWeight "500" ]

    -- Text Color: indigo
    , rule ".font-semibold" [ fontWeight "600" ]

    -- Text Color: violet
    , rule ".font-bold" [ fontWeight "700" ]

    -- Text Color: purple
    , rule ".font-extrabold" [ fontWeight "800" ]

    -- Text Color: fuchsia
    , rule ".font-black" [ fontWeight "900" ]

    -- Text Color: pink
    , rule ".font-sans"
        [ fontFamily
            "ui-sans-serif, system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\""
        ]

    -- Text Color: rose
    , rule ".font-serif"
        [ fontFamily
            "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif"
        ]

    -- Text Decoration
    , rule ".font-mono"
        [ fontFamily
            "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
        ]

    -- Text Transform
    , rule ".text-left" [ textAlign "left" ]

    -- Font Style
    , rule ".text-center" [ textAlign "center" ]

    -- Line Height
    , rule ".text-right" [ textAlign "right" ]

    -- Letter Spacing
    , rule ".text-justify" [ textAlign "justify" ]

    -- Whitespace
    , rule ".text-start" [ textAlign "start" ]

    -- Truncate / Overflow
    , rule ".text-end" [ textAlign "end" ]

    -- Word Break
    , rule ".text-transparent" [ color "transparent" ]

    -- List Style Type
    , rule ".text-black" [ color "#000000" ]

    -- List Style Position
    , rule ".text-white" [ color "#ffffff" ]

    -- Text Indent
    , rule ".text-current" [ color "currentColor" ]

    -- Vertical Align
    , rule ".text-slate-50" [ color "#f8fafc" ]

    -- Content
    , rule ".text-slate-100" [ color "#f1f5f9" ]

    -- Hyphens
    , rule ".text-slate-200" [ color "#e2e8f0" ]
    , rule ".text-slate-300" [ color "#cbd5e1" ]
    , rule ".text-slate-400" [ color "#94a3b8" ]
