    , rule ".space-y-12 > * + *" [ marginTop (lengthRaw "3rem") ]
    ]

-- ============================================================
-- Typography
-- ============================================================
typographyRules =
    [ rule ".text-xs" [ fontSize (lengthRaw "0.75rem") , lineHeight (lengthRaw "1rem") ]

    -- Font Weight
    , rule ".text-sm" [ fontSize (lengthRaw "0.875rem") , lineHeight (lengthRaw "1.25rem") ]

    -- Font Family
    , rule ".text-base" [ fontSize (lengthRaw "1rem") , lineHeight (lengthRaw "1.5rem") ]

    -- Text Align
    , rule ".text-lg" [ fontSize (lengthRaw "1.125rem") , lineHeight (lengthRaw "1.75rem") ]

    -- Text Color: black/white/transparent
    , rule ".text-xl" [ fontSize (lengthRaw "1.25rem") , lineHeight (lengthRaw "1.75rem") ]

    -- Text Color: slate
    , rule ".text-2xl" [ fontSize (lengthRaw "1.5rem") , lineHeight (lengthRaw "2rem") ]

    -- Text Color: gray
    , rule ".text-3xl" [ fontSize (lengthRaw "1.875rem") , lineHeight (lengthRaw "2.25rem") ]

    -- Text Color: red
    , rule ".text-4xl" [ fontSize (lengthRaw "2.25rem") , lineHeight (lengthRaw "2.5rem") ]

    -- Text Color: orange
    , rule ".text-5xl" [ fontSize (lengthRaw "3rem") , lineHeight (lengthRaw "1") ]

    -- Text Color: amber
    , rule ".text-6xl" [ fontSize (lengthRaw "3.75rem") , lineHeight (lengthRaw "1") ]

    -- Text Color: yellow
    , rule ".text-7xl" [ fontSize (lengthRaw "4.5rem") , lineHeight (lengthRaw "1") ]

    -- Text Color: lime
    , rule ".text-8xl" [ fontSize (lengthRaw "6rem") , lineHeight (lengthRaw "1") ]

    -- Text Color: green
    , rule ".text-9xl" [ fontSize (lengthRaw "8rem") , lineHeight (lengthRaw "1") ]

    -- Text Color: emerald
    , rule ".font-thin" [ fontWeight (FontWeightRaw "100") ]

    -- Text Color: teal
    , rule ".font-extralight" [ fontWeight (FontWeightRaw "200") ]

    -- Text Color: cyan
    , rule ".font-light" [ fontWeight (FontWeightRaw "300") ]

    -- Text Color: sky
    , rule ".font-normal" [ fontWeight (FontWeightRaw "400") ]

    -- Text Color: blue
    , rule ".font-medium" [ fontWeight (FontWeightRaw "500") ]

    -- Text Color: indigo
    , rule ".font-semibold" [ fontWeight (FontWeightRaw "600") ]

    -- Text Color: violet
    , rule ".font-bold" [ fontWeight (FontWeightRaw "700") ]

    -- Text Color: purple
    , rule ".font-extrabold" [ fontWeight (FontWeightRaw "800") ]

    -- Text Color: fuchsia
    , rule ".font-black" [ fontWeight (FontWeightRaw "900") ]

    -- Text Color: pink
    , rule ".font-sans"
        [ fontFamily
            "ui-sans-serif, system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\""
        ]

    -- Text Color: rose
    , rule ".font-serif"
        [ fontFamily
            "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif"
        ]

    -- Text Decoration
    , rule ".font-mono"
        [ fontFamily
            "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
        ]

    -- Text Transform
    , rule ".text-left" [ textAlign (TextAlignRaw "left") ]

    -- Font Style
    , rule ".text-center" [ textAlign (TextAlignRaw "center") ]

    -- Line Height
    , rule ".text-right" [ textAlign (TextAlignRaw "right") ]

    -- Letter Spacing
    , rule ".text-justify" [ textAlign (TextAlignRaw "justify") ]

    -- Whitespace
    , rule ".text-start" [ textAlign (TextAlignRaw "start") ]

    -- Truncate / Overflow
    , rule ".text-end" [ textAlign (TextAlignRaw "end") ]

    -- Word Break
    , rule ".text-transparent" [ color (colorRaw "transparent") ]

    -- List Style Type
    , rule ".text-black" [ color (colorRaw "#000000") ]

    -- List Style Position
    , rule ".text-white" [ color (colorRaw "#ffffff") ]

    -- Text Indent
    , rule ".text-current" [ color (colorRaw "currentColor") ]

    -- Vertical Align
    , rule ".text-slate-50" [ color (colorRaw "#f8fafc") ]

    -- Content
    , rule ".text-slate-100" [ color (colorRaw "#f1f5f9") ]

    -- Hyphens
    , rule ".text-slate-200" [ color (colorRaw "#e2e8f0") ]
    , rule ".text-slate-300" [ color (colorRaw "#cbd5e1") ]
    , rule ".text-slate-400" [ color (colorRaw "#94a3b8") ]
    , rule ".text-slate-500" [ color (colorRaw "#64748b") ]
    , rule ".text-slate-600" [ color (colorRaw "#475569") ]
    , rule ".text-slate-700" [ color (colorRaw "#334155") ]
    , rule ".text-slate-800" [ color (colorRaw "#1e293b") ]
    , rule ".text-slate-900" [ color (colorRaw "#0f172a") ]
    , rule ".text-gray-50" [ color (colorRaw "#f9fafb") ]
    , rule ".text-gray-100" [ color (colorRaw "#f3f4f6") ]
    , rule ".text-gray-200" [ color (colorRaw "#e5e7eb") ]
