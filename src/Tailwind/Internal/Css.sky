    , rule ".-translate-y-4" [ transform "translateY(-1rem)" ]
    , rule ".-translate-y-1\\/2" [ transform "translateY(-50%)" ]
    , rule ".-translate-y-full" [ transform "translateY(-100%)" ]
    , rule ".skew-x-0" [ transform "skewX(0deg)" ]
    , rule ".skew-x-1" [ transform "skewX(1deg)" ]
    , rule ".skew-x-2" [ transform "skewX(2deg)" ]
    , rule ".skew-x-3" [ transform "skewX(3deg)" ]
    , rule ".skew-x-6" [ transform "skewX(6deg)" ]
    , rule ".skew-x-12" [ transform "skewX(12deg)" ]
    , rule ".-skew-x-1" [ transform "skewX(-1deg)" ]
    , rule ".-skew-x-2" [ transform "skewX(-2deg)" ]
    , rule ".-skew-x-3" [ transform "skewX(-3deg)" ]
    , rule ".-skew-x-6" [ transform "skewX(-6deg)" ]
    , rule ".-skew-x-12" [ transform "skewX(-12deg)" ]
    , rule ".skew-y-0" [ transform "skewY(0deg)" ]
    , rule ".skew-y-1" [ transform "skewY(1deg)" ]
    , rule ".skew-y-2" [ transform "skewY(2deg)" ]
    , rule ".skew-y-3" [ transform "skewY(3deg)" ]
    , rule ".skew-y-6" [ transform "skewY(6deg)" ]
    , rule ".skew-y-12" [ transform "skewY(12deg)" ]
    , rule ".-skew-y-1" [ transform "skewY(-1deg)" ]
    , rule ".-skew-y-2" [ transform "skewY(-2deg)" ]
    , rule ".-skew-y-3" [ transform "skewY(-3deg)" ]
    , rule ".-skew-y-6" [ transform "skewY(-6deg)" ]
    , rule ".-skew-y-12" [ transform "skewY(-12deg)" ]
    , rule ".origin-center" [ property "transform-origin" "center" ]
    , rule ".origin-top" [ property "transform-origin" "top" ]
    , rule ".origin-top-right" [ property "transform-origin" "top right" ]
    , rule ".origin-right" [ property "transform-origin" "right" ]
    , rule ".origin-bottom-right" [ property "transform-origin" "bottom right" ]
    , rule ".origin-bottom" [ property "transform-origin" "bottom" ]
    , rule ".origin-bottom-left" [ property "transform-origin" "bottom left" ]
    , rule ".origin-left" [ property "transform-origin" "left" ]
    , rule ".origin-top-left" [ property "transform-origin" "top left" ]
    ]

-- ============================================================
-- Filters
-- ============================================================
filtersRules =
    [ rule ".blur-none" [ property "filter" "blur(0)" ]

    -- Brightness
    , rule ".blur-sm" [ property "filter" "blur(4px)" ]

    -- Contrast
    , rule ".blur" [ property "filter" "blur(8px)" ]

    -- Grayscale
    , rule ".blur-md" [ property "filter" "blur(12px)" ]

    -- Hue Rotate
    , rule ".blur-lg" [ property "filter" "blur(16px)" ]

    -- Invert
    , rule ".blur-xl" [ property "filter" "blur(24px)" ]

    -- Saturate
    , rule ".blur-2xl" [ property "filter" "blur(40px)" ]

    -- Sepia
    , rule ".blur-3xl" [ property "filter" "blur(64px)" ]

    -- Drop Shadow
    , rule ".brightness-0" [ property "filter" "brightness(0)" ]

    -- Backdrop Blur
    , rule ".brightness-50" [ property "filter" "brightness(.5)" ]

    -- Backdrop Brightness
    , rule ".brightness-75" [ property "filter" "brightness(.75)" ]

    -- Backdrop Contrast
    , rule ".brightness-90" [ property "filter" "brightness(.9)" ]

    -- Backdrop Grayscale
    , rule ".brightness-95" [ property "filter" "brightness(.95)" ]

    -- Backdrop Saturate
    , rule ".brightness-100" [ property "filter" "brightness(1)" ]

    -- Backdrop Sepia
    , rule ".brightness-105" [ property "filter" "brightness(1.05)" ]

    -- Backdrop Invert
    , rule ".brightness-110" [ property "filter" "brightness(1.1)" ]

    -- Backdrop Opacity
    , rule ".brightness-125" [ property "filter" "brightness(1.25)" ]
    , rule ".brightness-150" [ property "filter" "brightness(1.5)" ]
    , rule ".brightness-200" [ property "filter" "brightness(2)" ]
    , rule ".contrast-0" [ property "filter" "contrast(0)" ]
    , rule ".contrast-50" [ property "filter" "contrast(.5)" ]
    , rule ".contrast-75" [ property "filter" "contrast(.75)" ]
    , rule ".contrast-100" [ property "filter" "contrast(1)" ]
    , rule ".contrast-125" [ property "filter" "contrast(1.25)" ]
    , rule ".contrast-150" [ property "filter" "contrast(1.5)" ]
    , rule ".contrast-200" [ property "filter" "contrast(2)" ]
    , rule ".grayscale-0" [ property "filter" "grayscale(0)" ]
    , rule ".grayscale" [ property "filter" "grayscale(100%)" ]
    , rule ".hue-rotate-0" [ property "filter" "hue-rotate(0deg)" ]
    , rule ".hue-rotate-15" [ property "filter" "hue-rotate(15deg)" ]
    , rule ".hue-rotate-30" [ property "filter" "hue-rotate(30deg)" ]
    , rule ".hue-rotate-60" [ property "filter" "hue-rotate(60deg)" ]
    , rule ".hue-rotate-90" [ property "filter" "hue-rotate(90deg)" ]
    , rule ".hue-rotate-180" [ property "filter" "hue-rotate(180deg)" ]
    , rule ".invert-0" [ property "filter" "invert(0)" ]
    , rule ".invert" [ property "filter" "invert(100%)" ]
    , rule ".saturate-0" [ property "filter" "saturate(0)" ]
    , rule ".saturate-50" [ property "filter" "saturate(.5)" ]
    , rule ".saturate-100" [ property "filter" "saturate(1)" ]
    , rule ".saturate-150" [ property "filter" "saturate(1.5)" ]
    , rule ".saturate-200" [ property "filter" "saturate(2)" ]
    , rule ".sepia-0" [ property "filter" "sepia(0)" ]
    , rule ".sepia" [ property "filter" "sepia(100%)" ]
    , rule ".drop-shadow-sm"
        [ property "filter" "drop-shadow(0 1px 1px rgba(0,0,0,0.05))" ]
    , rule ".drop-shadow"
        [ property "filter"
            "drop-shadow(0 1px 2px rgba(0,0,0,0.1)) drop-shadow(0 1px 1px rgba(0,0,0,0.06))"
        ]
    , rule ".drop-shadow-md"
        [ property "filter"
            "drop-shadow(0 4px 3px rgba(0,0,0,0.07)) drop-shadow(0 2px 2px rgba(0,0,0,0.06))"
        ]
    , rule ".drop-shadow-lg"
        [ property "filter"
            "drop-shadow(0 10px 8px rgba(0,0,0,0.04)) drop-shadow(0 4px 3px rgba(0,0,0,0.1))"
        ]
    , rule ".drop-shadow-xl"
        [ property "filter"
            "drop-shadow(0 20px 13px rgba(0,0,0,0.03)) drop-shadow(0 8px 5px rgba(0,0,0,0.08))"
        ]
    , rule ".drop-shadow-2xl"
        [ property "filter" "drop-shadow(0 25px 25px rgba(0,0,0,0.15))" ]
    , rule ".drop-shadow-none" [ property "filter" "drop-shadow(0 0 #0000)" ]
    , rule ".backdrop-blur-none" [ property "backdrop-filter" "blur(0)" ]
    , rule ".backdrop-blur-sm" [ property "backdrop-filter" "blur(4px)" ]
    , rule ".backdrop-blur" [ property "backdrop-filter" "blur(8px)" ]
    , rule ".backdrop-blur-md" [ property "backdrop-filter" "blur(12px)" ]
    , rule ".backdrop-blur-lg" [ property "backdrop-filter" "blur(16px)" ]
    , rule ".backdrop-blur-xl" [ property "backdrop-filter" "blur(24px)" ]
    , rule ".backdrop-blur-2xl" [ property "backdrop-filter" "blur(40px)" ]
    , rule ".backdrop-blur-3xl" [ property "backdrop-filter" "blur(64px)" ]
    , rule ".backdrop-brightness-0"
        [ property "backdrop-filter" "brightness(0)" ]
    , rule ".backdrop-brightness-50"
        [ property "backdrop-filter" "brightness(.5)" ]
    , rule ".backdrop-brightness-75"
        [ property "backdrop-filter" "brightness(.75)" ]
    , rule ".backdrop-brightness-100"
        [ property "backdrop-filter" "brightness(1)" ]
    , rule ".backdrop-brightness-125"
        [ property "backdrop-filter" "brightness(1.25)" ]
    , rule ".backdrop-brightness-150"
        [ property "backdrop-filter" "brightness(1.5)" ]
    , rule ".backdrop-brightness-200"
        [ property "backdrop-filter" "brightness(2)" ]
    , rule ".backdrop-contrast-0" [ property "backdrop-filter" "contrast(0)" ]
    , rule ".backdrop-contrast-50" [ property "backdrop-filter" "contrast(.5)" ]
    , rule ".backdrop-contrast-100" [ property "backdrop-filter" "contrast(1)" ]
    , rule ".backdrop-contrast-150"
        [ property "backdrop-filter" "contrast(1.5)" ]
    , rule ".backdrop-contrast-200" [ property "backdrop-filter" "contrast(2)" ]
    , rule ".backdrop-grayscale-0" [ property "backdrop-filter" "grayscale(0)" ]
    , rule ".backdrop-grayscale"
        [ property "backdrop-filter" "grayscale(100%)" ]
    , rule ".backdrop-saturate-0" [ property "backdrop-filter" "saturate(0)" ]
    , rule ".backdrop-saturate-50" [ property "backdrop-filter" "saturate(.5)" ]
    , rule ".backdrop-saturate-100" [ property "backdrop-filter" "saturate(1)" ]
    , rule ".backdrop-saturate-150"
        [ property "backdrop-filter" "saturate(1.5)" ]
    , rule ".backdrop-saturate-200" [ property "backdrop-filter" "saturate(2)" ]
    , rule ".backdrop-sepia-0" [ property "backdrop-filter" "sepia(0)" ]
    , rule ".backdrop-sepia" [ property "backdrop-filter" "sepia(100%)" ]
    , rule ".backdrop-invert-0" [ property "backdrop-filter" "invert(0)" ]
    , rule ".backdrop-invert" [ property "backdrop-filter" "invert(100%)" ]
    , rule ".backdrop-opacity-0" [ property "backdrop-filter" "opacity(0)" ]
    , rule ".backdrop-opacity-50" [ property "backdrop-filter" "opacity(.5)" ]
    , rule ".backdrop-opacity-100" [ property "backdrop-filter" "opacity(1)" ]
    ]

-- ============================================================
-- Gradients
-- ============================================================
gradientRules =
    [ rule ".bg-gradient-to-t"
        [ property "background-image"
            "linear-gradient(to top, var(--tw-gradient-stops))"
        ]

    -- From colors (selected key colors)
    , rule ".bg-gradient-to-tr"
        [ property "background-image"
            "linear-gradient(to top right, var(--tw-gradient-stops))"
        ]

    -- Via colors
    , rule ".bg-gradient-to-r"
        [ property "background-image"
            "linear-gradient(to right, var(--tw-gradient-stops))"
        ]

    -- To colors
    , rule ".bg-gradient-to-br"
        [ property "background-image"
            "linear-gradient(to bottom right, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-b"
        [ property "background-image"
            "linear-gradient(to bottom, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-bl"
        [ property "background-image"
            "linear-gradient(to bottom left, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-l"
        [ property "background-image"
            "linear-gradient(to left, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-tl"
        [ property "background-image"
            "linear-gradient(to top left, var(--tw-gradient-stops))"
        ]
    , rule ".bg-none" [ property "background-image" "none" ]
    , rule ".from-transparent"
        [ property "--tw-gradient-from" "transparent"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-black"
        [ property "--tw-gradient-from" "#000000"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-white"
        [ property "--tw-gradient-from" "#ffffff"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-blue-400"
        [ property "--tw-gradient-from" "#60a5fa"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-blue-500"
        [ property "--tw-gradient-from" "#3b82f6"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-blue-600"
        [ property "--tw-gradient-from" "#2563eb"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-indigo-500"
        [ property "--tw-gradient-from" "#6366f1"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-purple-500"
        [ property "--tw-gradient-from" "#a855f7"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-purple-600"
        [ property "--tw-gradient-from" "#9333ea"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-pink-500"
        [ property "--tw-gradient-from" "#ec4899"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-red-500"
        [ property "--tw-gradient-from" "#ef4444"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-green-400"
        [ property "--tw-gradient-from" "#4ade80"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-green-500"
        [ property "--tw-gradient-from" "#22c55e"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-cyan-500"
        [ property "--tw-gradient-from" "#06b6d4"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-teal-500"
        [ property "--tw-gradient-from" "#14b8a6"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-transparent"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), transparent, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-blue-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #3b82f6, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-purple-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #a855f7, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-pink-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #ec4899, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-indigo-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #6366f1, var(--tw-gradient-to, transparent)"
        ]
    , rule ".to-transparent" [ property "--tw-gradient-to" "transparent" ]
    , rule ".to-black" [ property "--tw-gradient-to" "#000000" ]
    , rule ".to-white" [ property "--tw-gradient-to" "#ffffff" ]
    , rule ".to-blue-500" [ property "--tw-gradient-to" "#3b82f6" ]
    , rule ".to-blue-600" [ property "--tw-gradient-to" "#2563eb" ]
    , rule ".to-indigo-500" [ property "--tw-gradient-to" "#6366f1" ]
    , rule ".to-indigo-600" [ property "--tw-gradient-to" "#4f46e5" ]
    , rule ".to-purple-500" [ property "--tw-gradient-to" "#a855f7" ]
    , rule ".to-purple-600" [ property "--tw-gradient-to" "#9333ea" ]
    , rule ".to-pink-500" [ property "--tw-gradient-to" "#ec4899" ]
    , rule ".to-pink-600" [ property "--tw-gradient-to" "#db2777" ]
    , rule ".to-red-500" [ property "--tw-gradient-to" "#ef4444" ]
    , rule ".to-green-500" [ property "--tw-gradient-to" "#22c55e" ]
    , rule ".to-cyan-500" [ property "--tw-gradient-to" "#06b6d4" ]
    , rule ".to-teal-500" [ property "--tw-gradient-to" "#14b8a6" ]
    ]

-- ============================================================
-- Outline
-- ============================================================
outlineRules =
    [ rule ".outline-none"
        [ property "outline" "2px solid transparent"
        , property "outline-offset" "2px"
        ]
    , rule ".outline" [ property "outline-style" "solid" ]
    , rule ".outline-dashed" [ property "outline-style" "dashed" ]
    , rule ".outline-dotted" [ property "outline-style" "dotted" ]
    , rule ".outline-double" [ property "outline-style" "double" ]
    , rule ".outline-0" [ property "outline-width" "0px" ]
    , rule ".outline-1" [ property "outline-width" "1px" ]
    , rule ".outline-2" [ property "outline-width" "2px" ]
    , rule ".outline-4" [ property "outline-width" "4px" ]
    , rule ".outline-8" [ property "outline-width" "8px" ]
    , rule ".outline-offset-0" [ property "outline-offset" "0px" ]
    , rule ".outline-offset-1" [ property "outline-offset" "1px" ]
    , rule ".outline-offset-2" [ property "outline-offset" "2px" ]
    , rule ".outline-offset-4" [ property "outline-offset" "4px" ]
    , rule ".outline-offset-8" [ property "outline-offset" "8px" ]
    , rule ".outline-black" [ property "outline-color" "#000000" ]
    , rule ".outline-white" [ property "outline-color" "#ffffff" ]
    , rule ".outline-blue-500" [ property "outline-color" "#3b82f6" ]
    , rule ".outline-blue-600" [ property "outline-color" "#2563eb" ]
    , rule ".outline-indigo-500" [ property "outline-color" "#6366f1" ]
    , rule ".outline-red-500" [ property "outline-color" "#ef4444" ]
    , rule ".outline-green-500" [ property "outline-color" "#22c55e" ]
    , rule ".outline-gray-300" [ property "outline-color" "#d1d5db" ]
    , rule ".outline-gray-500" [ property "outline-color" "#6b7280" ]
    ]

-- ============================================================
-- Divide
-- ============================================================
divideRules =
    [ rule ".divide-x-0 > * + *" [ property "border-left-width" "0px" ]

    -- Divide Color
    , rule ".divide-x > * + *" [ property "border-left-width" "1px" ]

    -- Divide Style
    , rule ".divide-x-2 > * + *" [ property "border-left-width" "2px" ]
    , rule ".divide-x-4 > * + *" [ property "border-left-width" "4px" ]
    , rule ".divide-x-8 > * + *" [ property "border-left-width" "8px" ]
    , rule ".divide-y-0 > * + *" [ property "border-top-width" "0px" ]
    , rule ".divide-y > * + *" [ property "border-top-width" "1px" ]
    , rule ".divide-y-2 > * + *" [ property "border-top-width" "2px" ]
    , rule ".divide-y-4 > * + *" [ property "border-top-width" "4px" ]
    , rule ".divide-y-8 > * + *" [ property "border-top-width" "8px" ]
    , rule ".divide-transparent > * + *" [ borderColor "transparent" ]
    , rule ".divide-black > * + *" [ borderColor "#000000" ]
    , rule ".divide-white > * + *" [ borderColor "#ffffff" ]
    , rule ".divide-gray-100 > * + *" [ borderColor "#f3f4f6" ]
    , rule ".divide-gray-200 > * + *" [ borderColor "#e5e7eb" ]
    , rule ".divide-gray-300 > * + *" [ borderColor "#d1d5db" ]
    , rule ".divide-gray-400 > * + *" [ borderColor "#9ca3af" ]
    , rule ".divide-gray-500 > * + *" [ borderColor "#6b7280" ]
    , rule ".divide-slate-200 > * + *" [ borderColor "#e2e8f0" ]
    , rule ".divide-solid > * + *" [ borderStyle "solid" ]
    , rule ".divide-dashed > * + *" [ borderStyle "dashed" ]
    , rule ".divide-dotted > * + *" [ borderStyle "dotted" ]
    , rule ".divide-double > * + *" [ borderStyle "double" ]
    , rule ".divide-none > * + *" [ borderStyle "none" ]
    ]

-- ============================================================
-- Ring
-- ============================================================
ringRules =
    [ rule ".ring" [ property "box-shadow" "0 0 0 3px rgba(59, 130, 246, 0.5)" ]

    -- Ring Offset
    , rule ".ring-0" [ property "box-shadow" "0 0 0 0px transparent" ]

    -- Ring Color
    , rule ".ring-1"
        [ property "box-shadow" "0 0 0 1px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-2"
        [ property "box-shadow" "0 0 0 2px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-4"
        [ property "box-shadow" "0 0 0 4px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-8"
        [ property "box-shadow" "0 0 0 8px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-inset" [ property "--tw-ring-inset" "inset" ]
    , rule ".ring-offset-0"
        [ property "box-shadow"
            "0 0 0 0px #fff, 0 0 0 3px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-1"
        [ property "box-shadow"
            "0 0 0 1px #fff, 0 0 0 4px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-2"
        [ property "box-shadow"
            "0 0 0 2px #fff, 0 0 0 5px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-4"
        [ property "box-shadow"
            "0 0 0 4px #fff, 0 0 0 7px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-white" [ property "--tw-ring-offset-color" "#ffffff" ]
    , rule ".ring-offset-gray-50"
        [ property "--tw-ring-offset-color" "#f9fafb" ]
    , rule ".ring-transparent" [ property "--tw-ring-color" "transparent" ]
    , rule ".ring-black" [ property "--tw-ring-color" "#000000" ]
    , rule ".ring-white" [ property "--tw-ring-color" "#ffffff" ]
    , rule ".ring-gray-200" [ property "--tw-ring-color" "#e5e7eb" ]
    , rule ".ring-gray-300" [ property "--tw-ring-color" "#d1d5db" ]
    , rule ".ring-gray-500" [ property "--tw-ring-color" "#6b7280" ]
    , rule ".ring-blue-500" [ property "--tw-ring-color" "#3b82f6" ]
    , rule ".ring-blue-600" [ property "--tw-ring-color" "#2563eb" ]
    , rule ".ring-indigo-500" [ property "--tw-ring-color" "#6366f1" ]
    , rule ".ring-red-500" [ property "--tw-ring-color" "#ef4444" ]
    , rule ".ring-green-500" [ property "--tw-ring-color" "#22c55e" ]
    , rule ".ring-purple-500" [ property "--tw-ring-color" "#a855f7" ]
    , rule ".ring-pink-500" [ property "--tw-ring-color" "#ec4899" ]
    ]

-- ============================================================
-- Table
-- ============================================================
tableRules =
    [ rule ".table-auto" [ property "table-layout" "auto" ]
    , rule ".table-fixed" [ property "table-layout" "fixed" ]
    , rule ".caption-top" [ property "caption-side" "top" ]
    , rule ".caption-bottom" [ property "caption-side" "bottom" ]
    ]

-- ============================================================
-- Accessibility
-- ============================================================
accessibilityRules =
    [ rule ".sr-only"
        [ position "absolute"
        , width "1px"
        , height "1px"
        , padding "0"
        , margin "-1px"
        , overflow "hidden"
        , property "clip" "rect(0, 0, 0, 0)"
        , property "white-space" "nowrap"
        , borderWidth "0"
        ]
    , rule ".not-sr-only"
        [ position "static"
        , width "auto"
        , height "auto"
        , padding "0"
        , margin "0"
        , overflow "visible"
        , property "clip" "auto"
        , property "white-space" "normal"
        ]
