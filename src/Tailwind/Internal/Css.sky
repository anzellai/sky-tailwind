    , rule ".rotate-2" [ transform "rotate(2deg)" ]
    , rule ".rotate-3" [ transform "rotate(3deg)" ]
    , rule ".rotate-6" [ transform "rotate(6deg)" ]
    , rule ".rotate-12" [ transform "rotate(12deg)" ]
    , rule ".rotate-45" [ transform "rotate(45deg)" ]
    , rule ".rotate-90" [ transform "rotate(90deg)" ]
    , rule ".rotate-180" [ transform "rotate(180deg)" ]
    , rule ".-rotate-1" [ transform "rotate(-1deg)" ]
    , rule ".-rotate-2" [ transform "rotate(-2deg)" ]
    , rule ".-rotate-3" [ transform "rotate(-3deg)" ]
    , rule ".-rotate-6" [ transform "rotate(-6deg)" ]
    , rule ".-rotate-12" [ transform "rotate(-12deg)" ]
    , rule ".-rotate-45" [ transform "rotate(-45deg)" ]
    , rule ".-rotate-90" [ transform "rotate(-90deg)" ]
    , rule ".-rotate-180" [ transform "rotate(-180deg)" ]
    , rule ".translate-x-0" [ transform "translateX(0)" ]
    , rule ".translate-x-1" [ transform "translateX(0.25rem)" ]
    , rule ".translate-x-2" [ transform "translateX(0.5rem)" ]
    , rule ".translate-x-3" [ transform "translateX(0.75rem)" ]
