    , rule ".gap-x-1" [ property "column-gap" "0.25rem" ]
    , rule ".gap-x-2" [ property "column-gap" "0.5rem" ]
    , rule ".gap-x-3" [ property "column-gap" "0.75rem" ]
    , rule ".gap-x-4" [ property "column-gap" "1rem" ]
    , rule ".gap-x-6" [ property "column-gap" "1.5rem" ]
    , rule ".gap-x-8" [ property "column-gap" "2rem" ]
    , rule ".gap-y-0" [ property "row-gap" "0" ]
    , rule ".gap-y-1" [ property "row-gap" "0.25rem" ]
    , rule ".gap-y-2" [ property "row-gap" "0.5rem" ]
    , rule ".gap-y-3" [ property "row-gap" "0.75rem" ]
    , rule ".gap-y-4" [ property "row-gap" "1rem" ]
    , rule ".gap-y-6" [ property "row-gap" "1.5rem" ]
    , rule ".gap-y-8" [ property "row-gap" "2rem" ]
    , rule ".space-x-0 > * + *" [ marginLeft "0" ]
    , rule ".space-x-1 > * + *" [ marginLeft "0.25rem" ]
    , rule ".space-x-2 > * + *" [ marginLeft "0.5rem" ]
    , rule ".space-x-3 > * + *" [ marginLeft "0.75rem" ]
