module Tailwind.Internal.Css exposing (allRules)

import Sky.Core.Prelude exposing (..)
import Std.Css exposing (..)

allRules : String
allRules =
    stylesheet
        (

-- ============================================================
-- Base Reset
-- ============================================================
        baseRules ++

-- ============================================================
-- Spacing: padding, margin, gap, space
-- ============================================================
        spacingRules ++
        typographyRules ++
        layoutRules ++
        flexRules ++
        gridRules ++
        backgroundRules ++
        borderRules ++
        effectsRules ++
        sizingRules ++
        animationRules ++
        transformsRules ++
        filtersRules ++
        gradientRules ++
        outlineRules ++
        divideRules ++
        ringRules ++
        tableRules ++
        accessibilityRules ++ svgRules ++ interactivityRules ++ stateRules
        )

baseRules =
    [ rule "*, *::before, *::after" [ property "box-sizing" "border-box" ]

    -- Padding X (left + right)
    , rule "body" [ margin "0" , padding "0" ]
    ]

spacingRules =
    [ rule ".p-0" [ padding "0" ]

    -- Padding Y (top + bottom)
    , rule ".p-1" [ padding "0.25rem" ]

    -- Padding Top
    , rule ".p-2" [ padding "0.5rem" ]

    -- Padding Right
    , rule ".p-3" [ padding "0.75rem" ]

    -- Padding Bottom
    , rule ".p-4" [ padding "1rem" ]

    -- Padding Left
    , rule ".p-5" [ padding "1.25rem" ]

    -- Margin (all sides)
    , rule ".p-6" [ padding "1.5rem" ]

    -- Margin X (left + right)
    , rule ".p-8" [ padding "2rem" ]

    -- Margin Y (top + bottom)
    , rule ".p-10" [ padding "2.5rem" ]

    -- Margin Top
    , rule ".p-12" [ padding "3rem" ]

    -- Margin Right
    , rule ".p-16" [ padding "4rem" ]

    -- Margin Bottom
    , rule ".p-20" [ padding "5rem" ]

    -- Margin Left
    , rule ".p-24" [ padding "6rem" ]

    -- Negative margins
    , rule ".px-0" [ paddingLeft "0" , paddingRight "0" ]

    -- Gap
    , rule ".px-1" [ paddingLeft "0.25rem" , paddingRight "0.25rem" ]

    -- Space between (uses adjacent sibling selector)
    , rule ".px-2" [ paddingLeft "0.5rem" , paddingRight "0.5rem" ]
    , rule ".px-3" [ paddingLeft "0.75rem" , paddingRight "0.75rem" ]
    , rule ".px-4" [ paddingLeft "1rem" , paddingRight "1rem" ]
    , rule ".px-5" [ paddingLeft "1.25rem" , paddingRight "1.25rem" ]
    , rule ".px-6" [ paddingLeft "1.5rem" , paddingRight "1.5rem" ]
    , rule ".px-8" [ paddingLeft "2rem" , paddingRight "2rem" ]
    , rule ".px-10" [ paddingLeft "2.5rem" , paddingRight "2.5rem" ]
    , rule ".px-12" [ paddingLeft "3rem" , paddingRight "3rem" ]
    , rule ".px-16" [ paddingLeft "4rem" , paddingRight "4rem" ]
    , rule ".px-20" [ paddingLeft "5rem" , paddingRight "5rem" ]
    , rule ".px-24" [ paddingLeft "6rem" , paddingRight "6rem" ]
    , rule ".py-0" [ paddingTop "0" , paddingBottom "0" ]
    , rule ".py-1" [ paddingTop "0.25rem" , paddingBottom "0.25rem" ]
    , rule ".py-2" [ paddingTop "0.5rem" , paddingBottom "0.5rem" ]
    , rule ".py-3" [ paddingTop "0.75rem" , paddingBottom "0.75rem" ]
    , rule ".py-4" [ paddingTop "1rem" , paddingBottom "1rem" ]
    , rule ".py-5" [ paddingTop "1.25rem" , paddingBottom "1.25rem" ]
    , rule ".py-6" [ paddingTop "1.5rem" , paddingBottom "1.5rem" ]
    , rule ".py-8" [ paddingTop "2rem" , paddingBottom "2rem" ]
    , rule ".py-10" [ paddingTop "2.5rem" , paddingBottom "2.5rem" ]
    , rule ".py-12" [ paddingTop "3rem" , paddingBottom "3rem" ]
    , rule ".py-16" [ paddingTop "4rem" , paddingBottom "4rem" ]
    , rule ".py-20" [ paddingTop "5rem" , paddingBottom "5rem" ]
    , rule ".py-24" [ paddingTop "6rem" , paddingBottom "6rem" ]
    , rule ".pt-0" [ paddingTop "0" ]
    , rule ".pt-1" [ paddingTop "0.25rem" ]
    , rule ".pt-2" [ paddingTop "0.5rem" ]
    , rule ".pt-3" [ paddingTop "0.75rem" ]
    , rule ".pt-4" [ paddingTop "1rem" ]
    , rule ".pt-5" [ paddingTop "1.25rem" ]
    , rule ".pt-6" [ paddingTop "1.5rem" ]
    , rule ".pt-8" [ paddingTop "2rem" ]
    , rule ".pt-10" [ paddingTop "2.5rem" ]
    , rule ".pt-12" [ paddingTop "3rem" ]
    , rule ".pt-16" [ paddingTop "4rem" ]
    , rule ".pt-20" [ paddingTop "5rem" ]
    , rule ".pt-24" [ paddingTop "6rem" ]
    , rule ".pr-0" [ paddingRight "0" ]
    , rule ".pr-1" [ paddingRight "0.25rem" ]
    , rule ".pr-2" [ paddingRight "0.5rem" ]
    , rule ".pr-3" [ paddingRight "0.75rem" ]
    , rule ".pr-4" [ paddingRight "1rem" ]
    , rule ".pr-5" [ paddingRight "1.25rem" ]
    , rule ".pr-6" [ paddingRight "1.5rem" ]
