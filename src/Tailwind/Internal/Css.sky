-- ============================================================
-- Border
-- ============================================================
borderRules =
    [ rule ".border" [ border "1px solid" ]

    -- Border Color
    , rule ".border-0" [ borderWidth (lengthRaw "0px") ]

    -- Border Style
    , rule ".border-2" [ borderWidth (lengthRaw "2px") ]

    -- Border Radius
    , rule ".border-4" [ borderWidth (lengthRaw "4px") ]

    -- Border Collapse (for tables)
    , rule ".border-8" [ borderWidth (lengthRaw "8px") ]

    -- Border Spacing
    , rule ".border-t" [ borderTop "1px solid" ]
