    -- Hover: border color
    , rule ".hover\\:bg-slate-800:hover" [ backgroundColor "#1e293b" ]

    -- Hover: translate
    , rule ".hover\\:bg-gray-50:hover" [ backgroundColor "#f9fafb" ]

    -- Hover: rotate
    , rule ".hover\\:bg-gray-100:hover" [ backgroundColor "#f3f4f6" ]

    -- Hover: brightness
    , rule ".hover\\:bg-gray-200:hover" [ backgroundColor "#e5e7eb" ]

    -- Focus: outline
    , rule ".hover\\:bg-gray-300:hover" [ backgroundColor "#d1d5db" ]

    -- Focus: ring
