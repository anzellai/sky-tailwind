    -- First child
    , rule ".hover\\:bg-red-800:hover" [ backgroundColor (colorRaw "#991b1b") ]

    -- Last child
    , rule ".hover\\:bg-orange-500:hover" [ backgroundColor (colorRaw "#f97316") ]

    -- Odd/Even
