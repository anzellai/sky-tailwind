    , rule ".max-w-prose" [ maxWidth (lengthRaw "65ch") ]
    , rule ".max-w-screen-sm" [ maxWidth (lengthRaw "640px") ]
    , rule ".max-w-screen-md" [ maxWidth (lengthRaw "768px") ]
    , rule ".max-w-screen-lg" [ maxWidth (lengthRaw "1024px") ]
    , rule ".max-w-screen-xl" [ maxWidth (lengthRaw "1280px") ]
    , rule ".max-w-screen-2xl" [ maxWidth (lengthRaw "1536px") ]
    , rule ".min-h-0" [ minHeight (lengthRaw "0") ]
    , rule ".min-h-full" [ minHeight (lengthRaw "100%") ]
    , rule ".min-h-screen" [ minHeight (lengthRaw "100vh") ]
    , rule ".min-h-svh" [ minHeight (lengthRaw "100svh") ]
    , rule ".min-h-dvh" [ minHeight (lengthRaw "100dvh") ]
    , rule ".min-h-fit" [ minHeight (lengthRaw "fit-content") ]
    , rule ".min-h-min" [ minHeight (lengthRaw "min-content") ]
    , rule ".min-h-max" [ minHeight (lengthRaw "max-content") ]
    , rule ".max-h-none" [ maxHeight (lengthRaw "none") ]
    , rule ".max-h-full" [ maxHeight (lengthRaw "100%") ]
    , rule ".max-h-screen" [ maxHeight (lengthRaw "100vh") ]
    , rule ".max-h-svh" [ maxHeight (lengthRaw "100svh") ]
    , rule ".max-h-fit" [ maxHeight (lengthRaw "fit-content") ]
    , rule ".max-h-min" [ maxHeight (lengthRaw "min-content") ]
    , rule ".max-h-max" [ maxHeight (lengthRaw "max-content") ]
    , rule ".max-h-0" [ maxHeight (lengthRaw "0") ]
    , rule ".max-h-4" [ maxHeight (lengthRaw "1rem") ]
    , rule ".max-h-8" [ maxHeight (lengthRaw "2rem") ]
    , rule ".max-h-12" [ maxHeight (lengthRaw "3rem") ]
    , rule ".max-h-16" [ maxHeight (lengthRaw "4rem") ]
    , rule ".max-h-24" [ maxHeight (lengthRaw "6rem") ]
    , rule ".max-h-32" [ maxHeight (lengthRaw "8rem") ]
    , rule ".max-h-48" [ maxHeight (lengthRaw "12rem") ]
    , rule ".max-h-64" [ maxHeight (lengthRaw "16rem") ]
    , rule ".max-h-96" [ maxHeight (lengthRaw "24rem") ]
    , rule ".aspect-auto" [ property "aspect-ratio" "auto" ]
    , rule ".aspect-square" [ property "aspect-ratio" "1 / 1" ]
    , rule ".aspect-video" [ property "aspect-ratio" "16 / 9" ]
    , rule ".object-contain" [ property "object-fit" "contain" ]
    , rule ".object-cover" [ property "object-fit" "cover" ]
    , rule ".object-fill" [ property "object-fit" "fill" ]
    , rule ".object-none" [ property "object-fit" "none" ]
    , rule ".object-scale-down" [ property "object-fit" "scale-down" ]
    , rule ".object-bottom" [ property "object-position" "bottom" ]
    , rule ".object-center" [ property "object-position" "center" ]
    , rule ".object-left" [ property "object-position" "left" ]
    , rule ".object-left-bottom" [ property "object-position" "left bottom" ]
    , rule ".object-left-top" [ property "object-position" "left top" ]
    , rule ".object-right" [ property "object-position" "right" ]
    , rule ".object-right-bottom" [ property "object-position" "right bottom" ]
    , rule ".object-right-top" [ property "object-position" "right top" ]
    , rule ".object-top" [ property "object-position" "top" ]
    , rule ".box-border" [ property "box-sizing" "border-box" ]
    , rule ".box-content" [ property "box-sizing" "content-box" ]
    , rule ".container" [ width (lengthRaw "100%") ]
    ]

-- ============================================================
-- Animation
-- ============================================================
animationRules =
    [ keyframes "spin" [ frame "to" [ rawProp "transform:rotate(360deg)" ] ]
    , keyframes "ping"
        [ frame "75%, 100%" [ rawProp "transform:scale(2)" , rawProp "opacity:0" ] ]
    , keyframes "pulse" [ frame "50%" [ rawProp "opacity:.5" ] ]
    , keyframes "bounce"
        [ frame "0%, 100%"
            [ rawProp "transform:translateY(-25%)"
            , rawProp "animation-timing-function:cubic-bezier(0.8, 0, 1, 1)"
            ]
        , frame "50%"
            [ rawProp "transform:none"
            , rawProp "animation-timing-function:cubic-bezier(0, 0, 0.2, 1)"
            ]
        ]
    , rule ".animate-none" [ property "animation" "none" ]
    , rule ".animate-spin" [ property "animation" "spin 1s linear infinite" ]
    , rule ".animate-ping"
        [ property "animation" "ping 1s cubic-bezier(0, 0, 0.2, 1) infinite" ]
    , rule ".animate-pulse"
        [ property "animation" "pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite"
        ]
    , rule ".animate-bounce" [ property "animation" "bounce 1s infinite" ]
    ]

-- ============================================================
-- Transforms: scale, rotate, translate, skew, origin
-- ============================================================
transformsRules =
    [ rule ".scale-0" [ transform "scale(0)" ]

    -- Rotate
    , rule ".scale-50" [ transform "scale(.5)" ]

    -- Translate X
    , rule ".scale-75" [ transform "scale(.75)" ]

    -- Translate Y
    , rule ".scale-90" [ transform "scale(.9)" ]

    -- Skew
    , rule ".scale-95" [ transform "scale(.95)" ]

    -- Transform Origin
    , rule ".scale-100" [ transform "scale(1)" ]
    , rule ".scale-105" [ transform "scale(1.05)" ]
    , rule ".scale-110" [ transform "scale(1.1)" ]
    , rule ".scale-125" [ transform "scale(1.25)" ]
    , rule ".scale-150" [ transform "scale(1.5)" ]
    , rule ".scale-x-0" [ transform "scaleX(0)" ]
    , rule ".scale-x-50" [ transform "scaleX(.5)" ]
    , rule ".scale-x-100" [ transform "scaleX(1)" ]
    , rule ".scale-y-0" [ transform "scaleY(0)" ]
    , rule ".scale-y-50" [ transform "scaleY(.5)" ]
    , rule ".scale-y-100" [ transform "scaleY(1)" ]
    , rule ".rotate-0" [ transform "rotate(0deg)" ]
    , rule ".rotate-1" [ transform "rotate(1deg)" ]
    , rule ".rotate-2" [ transform "rotate(2deg)" ]
    , rule ".rotate-3" [ transform "rotate(3deg)" ]
    , rule ".rotate-6" [ transform "rotate(6deg)" ]
    , rule ".rotate-12" [ transform "rotate(12deg)" ]
    , rule ".rotate-45" [ transform "rotate(45deg)" ]
    , rule ".rotate-90" [ transform "rotate(90deg)" ]
    , rule ".rotate-180" [ transform "rotate(180deg)" ]
    , rule ".-rotate-1" [ transform "rotate(-1deg)" ]
    , rule ".-rotate-2" [ transform "rotate(-2deg)" ]
    , rule ".-rotate-3" [ transform "rotate(-3deg)" ]
    , rule ".-rotate-6" [ transform "rotate(-6deg)" ]
    , rule ".-rotate-12" [ transform "rotate(-12deg)" ]
    , rule ".-rotate-45" [ transform "rotate(-45deg)" ]
    , rule ".-rotate-90" [ transform "rotate(-90deg)" ]
    , rule ".-rotate-180" [ transform "rotate(-180deg)" ]
    , rule ".translate-x-0" [ transform "translateX(0)" ]
    , rule ".translate-x-1" [ transform "translateX(0.25rem)" ]
    , rule ".translate-x-2" [ transform "translateX(0.5rem)" ]
    , rule ".translate-x-3" [ transform "translateX(0.75rem)" ]
    , rule ".translate-x-4" [ transform "translateX(1rem)" ]
    , rule ".translate-x-5" [ transform "translateX(1.25rem)" ]
    , rule ".translate-x-6" [ transform "translateX(1.5rem)" ]
    , rule ".translate-x-8" [ transform "translateX(2rem)" ]
    , rule ".translate-x-10" [ transform "translateX(2.5rem)" ]
    , rule ".translate-x-12" [ transform "translateX(3rem)" ]
    , rule ".translate-x-1\\/2" [ transform "translateX(50%)" ]
    , rule ".translate-x-full" [ transform "translateX(100%)" ]
    , rule ".-translate-x-1" [ transform "translateX(-0.25rem)" ]
    , rule ".-translate-x-2" [ transform "translateX(-0.5rem)" ]
    , rule ".-translate-x-4" [ transform "translateX(-1rem)" ]
    , rule ".-translate-x-1\\/2" [ transform "translateX(-50%)" ]
    , rule ".-translate-x-full" [ transform "translateX(-100%)" ]
    , rule ".translate-y-0" [ transform "translateY(0)" ]
    , rule ".translate-y-1" [ transform "translateY(0.25rem)" ]
    , rule ".translate-y-2" [ transform "translateY(0.5rem)" ]
    , rule ".translate-y-3" [ transform "translateY(0.75rem)" ]
    , rule ".translate-y-4" [ transform "translateY(1rem)" ]
    , rule ".translate-y-5" [ transform "translateY(1.25rem)" ]
    , rule ".translate-y-6" [ transform "translateY(1.5rem)" ]
    , rule ".translate-y-8" [ transform "translateY(2rem)" ]
    , rule ".translate-y-10" [ transform "translateY(2.5rem)" ]
    , rule ".translate-y-12" [ transform "translateY(3rem)" ]
    , rule ".translate-y-1\\/2" [ transform "translateY(50%)" ]
    , rule ".translate-y-full" [ transform "translateY(100%)" ]
    , rule ".-translate-y-1" [ transform "translateY(-0.25rem)" ]
    , rule ".-translate-y-2" [ transform "translateY(-0.5rem)" ]
    , rule ".-translate-y-4" [ transform "translateY(-1rem)" ]
    , rule ".-translate-y-1\\/2" [ transform "translateY(-50%)" ]
    , rule ".-translate-y-full" [ transform "translateY(-100%)" ]
    , rule ".skew-x-0" [ transform "skewX(0deg)" ]
    , rule ".skew-x-1" [ transform "skewX(1deg)" ]
    , rule ".skew-x-2" [ transform "skewX(2deg)" ]
    , rule ".skew-x-3" [ transform "skewX(3deg)" ]
    , rule ".skew-x-6" [ transform "skewX(6deg)" ]
    , rule ".skew-x-12" [ transform "skewX(12deg)" ]
    , rule ".-skew-x-1" [ transform "skewX(-1deg)" ]
    , rule ".-skew-x-2" [ transform "skewX(-2deg)" ]
    , rule ".-skew-x-3" [ transform "skewX(-3deg)" ]
    , rule ".-skew-x-6" [ transform "skewX(-6deg)" ]
    , rule ".-skew-x-12" [ transform "skewX(-12deg)" ]
    , rule ".skew-y-0" [ transform "skewY(0deg)" ]
    , rule ".skew-y-1" [ transform "skewY(1deg)" ]
    , rule ".skew-y-2" [ transform "skewY(2deg)" ]
    , rule ".skew-y-3" [ transform "skewY(3deg)" ]
    , rule ".skew-y-6" [ transform "skewY(6deg)" ]
    , rule ".skew-y-12" [ transform "skewY(12deg)" ]
    , rule ".-skew-y-1" [ transform "skewY(-1deg)" ]
    , rule ".-skew-y-2" [ transform "skewY(-2deg)" ]
    , rule ".-skew-y-3" [ transform "skewY(-3deg)" ]
    , rule ".-skew-y-6" [ transform "skewY(-6deg)" ]
    , rule ".-skew-y-12" [ transform "skewY(-12deg)" ]
    , rule ".origin-center" [ property "transform-origin" "center" ]
    , rule ".origin-top" [ property "transform-origin" "top" ]
    , rule ".origin-top-right" [ property "transform-origin" "top right" ]
    , rule ".origin-right" [ property "transform-origin" "right" ]
    , rule ".origin-bottom-right" [ property "transform-origin" "bottom right" ]
    , rule ".origin-bottom" [ property "transform-origin" "bottom" ]
    , rule ".origin-bottom-left" [ property "transform-origin" "bottom left" ]
    , rule ".origin-left" [ property "transform-origin" "left" ]
    , rule ".origin-top-left" [ property "transform-origin" "top left" ]
    ]

-- ============================================================
-- Filters
-- ============================================================
filtersRules =
    [ rule ".blur-none" [ property "filter" "blur(0)" ]

    -- Brightness
    , rule ".blur-sm" [ property "filter" "blur(4px)" ]

    -- Contrast
    , rule ".blur" [ property "filter" "blur(8px)" ]

    -- Grayscale
    , rule ".blur-md" [ property "filter" "blur(12px)" ]

    -- Hue Rotate
    , rule ".blur-lg" [ property "filter" "blur(16px)" ]

    -- Invert
    , rule ".blur-xl" [ property "filter" "blur(24px)" ]

    -- Saturate
    , rule ".blur-2xl" [ property "filter" "blur(40px)" ]

    -- Sepia
    , rule ".blur-3xl" [ property "filter" "blur(64px)" ]

    -- Drop Shadow
    , rule ".brightness-0" [ property "filter" "brightness(0)" ]

    -- Backdrop Blur
    , rule ".brightness-50" [ property "filter" "brightness(.5)" ]

    -- Backdrop Brightness
    , rule ".brightness-75" [ property "filter" "brightness(.75)" ]

    -- Backdrop Contrast
    , rule ".brightness-90" [ property "filter" "brightness(.9)" ]

    -- Backdrop Grayscale
    , rule ".brightness-95" [ property "filter" "brightness(.95)" ]

    -- Backdrop Saturate
    , rule ".brightness-100" [ property "filter" "brightness(1)" ]

    -- Backdrop Sepia
    , rule ".brightness-105" [ property "filter" "brightness(1.05)" ]

    -- Backdrop Invert
    , rule ".brightness-110" [ property "filter" "brightness(1.1)" ]

    -- Backdrop Opacity
    , rule ".brightness-125" [ property "filter" "brightness(1.25)" ]
    , rule ".brightness-150" [ property "filter" "brightness(1.5)" ]
    , rule ".brightness-200" [ property "filter" "brightness(2)" ]
    , rule ".contrast-0" [ property "filter" "contrast(0)" ]
    , rule ".contrast-50" [ property "filter" "contrast(.5)" ]
    , rule ".contrast-75" [ property "filter" "contrast(.75)" ]
    , rule ".contrast-100" [ property "filter" "contrast(1)" ]
    , rule ".contrast-125" [ property "filter" "contrast(1.25)" ]
    , rule ".contrast-150" [ property "filter" "contrast(1.5)" ]
    , rule ".contrast-200" [ property "filter" "contrast(2)" ]
    , rule ".grayscale-0" [ property "filter" "grayscale(0)" ]
    , rule ".grayscale" [ property "filter" "grayscale(100%)" ]
    , rule ".hue-rotate-0" [ property "filter" "hue-rotate(0deg)" ]
    , rule ".hue-rotate-15" [ property "filter" "hue-rotate(15deg)" ]
    , rule ".hue-rotate-30" [ property "filter" "hue-rotate(30deg)" ]
    , rule ".hue-rotate-60" [ property "filter" "hue-rotate(60deg)" ]
    , rule ".hue-rotate-90" [ property "filter" "hue-rotate(90deg)" ]
    , rule ".hue-rotate-180" [ property "filter" "hue-rotate(180deg)" ]
    , rule ".invert-0" [ property "filter" "invert(0)" ]
    , rule ".invert" [ property "filter" "invert(100%)" ]
    , rule ".saturate-0" [ property "filter" "saturate(0)" ]
    , rule ".saturate-50" [ property "filter" "saturate(.5)" ]
    , rule ".saturate-100" [ property "filter" "saturate(1)" ]
    , rule ".saturate-150" [ property "filter" "saturate(1.5)" ]
    , rule ".saturate-200" [ property "filter" "saturate(2)" ]
    , rule ".sepia-0" [ property "filter" "sepia(0)" ]
    , rule ".sepia" [ property "filter" "sepia(100%)" ]
    , rule ".drop-shadow-sm"
        [ property "filter" "drop-shadow(0 1px 1px rgba(0,0,0,0.05))" ]
    , rule ".drop-shadow"
        [ property "filter"
            "drop-shadow(0 1px 2px rgba(0,0,0,0.1)) drop-shadow(0 1px 1px rgba(0,0,0,0.06))"
        ]
    , rule ".drop-shadow-md"
        [ property "filter"
            "drop-shadow(0 4px 3px rgba(0,0,0,0.07)) drop-shadow(0 2px 2px rgba(0,0,0,0.06))"
        ]
    , rule ".drop-shadow-lg"
        [ property "filter"
            "drop-shadow(0 10px 8px rgba(0,0,0,0.04)) drop-shadow(0 4px 3px rgba(0,0,0,0.1))"
        ]
    , rule ".drop-shadow-xl"
        [ property "filter"
            "drop-shadow(0 20px 13px rgba(0,0,0,0.03)) drop-shadow(0 8px 5px rgba(0,0,0,0.08))"
        ]
    , rule ".drop-shadow-2xl"
        [ property "filter" "drop-shadow(0 25px 25px rgba(0,0,0,0.15))" ]
    , rule ".drop-shadow-none" [ property "filter" "drop-shadow(0 0 #0000)" ]
    , rule ".backdrop-blur-none" [ property "backdrop-filter" "blur(0)" ]
    , rule ".backdrop-blur-sm" [ property "backdrop-filter" "blur(4px)" ]
    , rule ".backdrop-blur" [ property "backdrop-filter" "blur(8px)" ]
    , rule ".backdrop-blur-md" [ property "backdrop-filter" "blur(12px)" ]
    , rule ".backdrop-blur-lg" [ property "backdrop-filter" "blur(16px)" ]
    , rule ".backdrop-blur-xl" [ property "backdrop-filter" "blur(24px)" ]
    , rule ".backdrop-blur-2xl" [ property "backdrop-filter" "blur(40px)" ]
    , rule ".backdrop-blur-3xl" [ property "backdrop-filter" "blur(64px)" ]
    , rule ".backdrop-brightness-0"
        [ property "backdrop-filter" "brightness(0)" ]
    , rule ".backdrop-brightness-50"
        [ property "backdrop-filter" "brightness(.5)" ]
    , rule ".backdrop-brightness-75"
        [ property "backdrop-filter" "brightness(.75)" ]
    , rule ".backdrop-brightness-100"
        [ property "backdrop-filter" "brightness(1)" ]
    , rule ".backdrop-brightness-125"
        [ property "backdrop-filter" "brightness(1.25)" ]
    , rule ".backdrop-brightness-150"
        [ property "backdrop-filter" "brightness(1.5)" ]
    , rule ".backdrop-brightness-200"
        [ property "backdrop-filter" "brightness(2)" ]
    , rule ".backdrop-contrast-0" [ property "backdrop-filter" "contrast(0)" ]
    , rule ".backdrop-contrast-50" [ property "backdrop-filter" "contrast(.5)" ]
    , rule ".backdrop-contrast-100" [ property "backdrop-filter" "contrast(1)" ]
    , rule ".backdrop-contrast-150"
        [ property "backdrop-filter" "contrast(1.5)" ]
    , rule ".backdrop-contrast-200" [ property "backdrop-filter" "contrast(2)" ]
    , rule ".backdrop-grayscale-0" [ property "backdrop-filter" "grayscale(0)" ]
    , rule ".backdrop-grayscale"
        [ property "backdrop-filter" "grayscale(100%)" ]
    , rule ".backdrop-saturate-0" [ property "backdrop-filter" "saturate(0)" ]
    , rule ".backdrop-saturate-50" [ property "backdrop-filter" "saturate(.5)" ]
    , rule ".backdrop-saturate-100" [ property "backdrop-filter" "saturate(1)" ]
    , rule ".backdrop-saturate-150"
        [ property "backdrop-filter" "saturate(1.5)" ]
    , rule ".backdrop-saturate-200" [ property "backdrop-filter" "saturate(2)" ]
    , rule ".backdrop-sepia-0" [ property "backdrop-filter" "sepia(0)" ]
    , rule ".backdrop-sepia" [ property "backdrop-filter" "sepia(100%)" ]
    , rule ".backdrop-invert-0" [ property "backdrop-filter" "invert(0)" ]
    , rule ".backdrop-invert" [ property "backdrop-filter" "invert(100%)" ]
    , rule ".backdrop-opacity-0" [ property "backdrop-filter" "opacity(0)" ]
    , rule ".backdrop-opacity-50" [ property "backdrop-filter" "opacity(.5)" ]
    , rule ".backdrop-opacity-100" [ property "backdrop-filter" "opacity(1)" ]
    ]

-- ============================================================
-- Gradients
-- ============================================================
gradientRules =
    [ rule ".bg-gradient-to-t"
        [ property "background-image"
            "linear-gradient(to top, var(--tw-gradient-stops))"
        ]

    -- From colors (selected key colors)
    , rule ".bg-gradient-to-tr"
        [ property "background-image"
            "linear-gradient(to top right, var(--tw-gradient-stops))"
        ]

    -- Via colors
    , rule ".bg-gradient-to-r"
        [ property "background-image"
            "linear-gradient(to right, var(--tw-gradient-stops))"
        ]

    -- To colors
    , rule ".bg-gradient-to-br"
        [ property "background-image"
            "linear-gradient(to bottom right, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-b"
        [ property "background-image"
            "linear-gradient(to bottom, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-bl"
        [ property "background-image"
            "linear-gradient(to bottom left, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-l"
        [ property "background-image"
            "linear-gradient(to left, var(--tw-gradient-stops))"
        ]
    , rule ".bg-gradient-to-tl"
        [ property "background-image"
            "linear-gradient(to top left, var(--tw-gradient-stops))"
        ]
    , rule ".bg-none" [ property "background-image" "none" ]
    , rule ".from-transparent"
        [ property "--tw-gradient-from" "transparent"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-black"
        [ property "--tw-gradient-from" "#000000"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-white"
        [ property "--tw-gradient-from" "#ffffff"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-blue-400"
        [ property "--tw-gradient-from" "#60a5fa"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-blue-500"
        [ property "--tw-gradient-from" "#3b82f6"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-blue-600"
        [ property "--tw-gradient-from" "#2563eb"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-indigo-500"
        [ property "--tw-gradient-from" "#6366f1"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-purple-500"
        [ property "--tw-gradient-from" "#a855f7"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-purple-600"
        [ property "--tw-gradient-from" "#9333ea"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-pink-500"
        [ property "--tw-gradient-from" "#ec4899"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-red-500"
        [ property "--tw-gradient-from" "#ef4444"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-green-400"
        [ property "--tw-gradient-from" "#4ade80"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-green-500"
        [ property "--tw-gradient-from" "#22c55e"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-cyan-500"
        [ property "--tw-gradient-from" "#06b6d4"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".from-teal-500"
        [ property "--tw-gradient-from" "#14b8a6"
        , property "--tw-gradient-stops"
            "var(--tw-gradient-from), var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-transparent"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), transparent, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-blue-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #3b82f6, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-purple-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #a855f7, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-pink-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #ec4899, var(--tw-gradient-to, transparent)"
        ]
    , rule ".via-indigo-500"
        [ property "--tw-gradient-stops"
            "var(--tw-gradient-from), #6366f1, var(--tw-gradient-to, transparent)"
        ]
    , rule ".to-transparent" [ property "--tw-gradient-to" "transparent" ]
    , rule ".to-black" [ property "--tw-gradient-to" "#000000" ]
    , rule ".to-white" [ property "--tw-gradient-to" "#ffffff" ]
    , rule ".to-blue-500" [ property "--tw-gradient-to" "#3b82f6" ]
    , rule ".to-blue-600" [ property "--tw-gradient-to" "#2563eb" ]
    , rule ".to-indigo-500" [ property "--tw-gradient-to" "#6366f1" ]
    , rule ".to-indigo-600" [ property "--tw-gradient-to" "#4f46e5" ]
    , rule ".to-purple-500" [ property "--tw-gradient-to" "#a855f7" ]
    , rule ".to-purple-600" [ property "--tw-gradient-to" "#9333ea" ]
    , rule ".to-pink-500" [ property "--tw-gradient-to" "#ec4899" ]
    , rule ".to-pink-600" [ property "--tw-gradient-to" "#db2777" ]
    , rule ".to-red-500" [ property "--tw-gradient-to" "#ef4444" ]
    , rule ".to-green-500" [ property "--tw-gradient-to" "#22c55e" ]
    , rule ".to-cyan-500" [ property "--tw-gradient-to" "#06b6d4" ]
    , rule ".to-teal-500" [ property "--tw-gradient-to" "#14b8a6" ]
    ]

-- ============================================================
-- Outline
-- ============================================================
outlineRules =
    [ rule ".outline-none"
        [ property "outline" "2px solid transparent"
        , property "outline-offset" "2px"
        ]
    , rule ".outline" [ property "outline-style" "solid" ]
    , rule ".outline-dashed" [ property "outline-style" "dashed" ]
    , rule ".outline-dotted" [ property "outline-style" "dotted" ]
    , rule ".outline-double" [ property "outline-style" "double" ]
    , rule ".outline-0" [ property "outline-width" "0px" ]
    , rule ".outline-1" [ property "outline-width" "1px" ]
    , rule ".outline-2" [ property "outline-width" "2px" ]
    , rule ".outline-4" [ property "outline-width" "4px" ]
    , rule ".outline-8" [ property "outline-width" "8px" ]
    , rule ".outline-offset-0" [ property "outline-offset" "0px" ]
    , rule ".outline-offset-1" [ property "outline-offset" "1px" ]
    , rule ".outline-offset-2" [ property "outline-offset" "2px" ]
    , rule ".outline-offset-4" [ property "outline-offset" "4px" ]
    , rule ".outline-offset-8" [ property "outline-offset" "8px" ]
    , rule ".outline-black" [ property "outline-color" "#000000" ]
    , rule ".outline-white" [ property "outline-color" "#ffffff" ]
    , rule ".outline-blue-500" [ property "outline-color" "#3b82f6" ]
    , rule ".outline-blue-600" [ property "outline-color" "#2563eb" ]
    , rule ".outline-indigo-500" [ property "outline-color" "#6366f1" ]
    , rule ".outline-red-500" [ property "outline-color" "#ef4444" ]
    , rule ".outline-green-500" [ property "outline-color" "#22c55e" ]
    , rule ".outline-gray-300" [ property "outline-color" "#d1d5db" ]
    , rule ".outline-gray-500" [ property "outline-color" "#6b7280" ]
    ]

-- ============================================================
-- Divide
-- ============================================================
divideRules =
    [ rule ".divide-x-0 > * + *" [ property "border-left-width" "0px" ]

    -- Divide Color
    , rule ".divide-x > * + *" [ property "border-left-width" "1px" ]

    -- Divide Style
    , rule ".divide-x-2 > * + *" [ property "border-left-width" "2px" ]
    , rule ".divide-x-4 > * + *" [ property "border-left-width" "4px" ]
    , rule ".divide-x-8 > * + *" [ property "border-left-width" "8px" ]
    , rule ".divide-y-0 > * + *" [ property "border-top-width" "0px" ]
    , rule ".divide-y > * + *" [ property "border-top-width" "1px" ]
    , rule ".divide-y-2 > * + *" [ property "border-top-width" "2px" ]
    , rule ".divide-y-4 > * + *" [ property "border-top-width" "4px" ]
    , rule ".divide-y-8 > * + *" [ property "border-top-width" "8px" ]
    , rule ".divide-transparent > * + *" [ borderColor (colorRaw "transparent") ]
    , rule ".divide-black > * + *" [ borderColor (colorRaw "#000000") ]
    , rule ".divide-white > * + *" [ borderColor (colorRaw "#ffffff") ]
    , rule ".divide-gray-100 > * + *" [ borderColor (colorRaw "#f3f4f6") ]
    , rule ".divide-gray-200 > * + *" [ borderColor (colorRaw "#e5e7eb") ]
    , rule ".divide-gray-300 > * + *" [ borderColor (colorRaw "#d1d5db") ]
    , rule ".divide-gray-400 > * + *" [ borderColor (colorRaw "#9ca3af") ]
    , rule ".divide-gray-500 > * + *" [ borderColor (colorRaw "#6b7280") ]
    , rule ".divide-slate-200 > * + *" [ borderColor (colorRaw "#e2e8f0") ]
    , rule ".divide-solid > * + *" [ borderStyle (BorderStyleRaw "solid") ]
    , rule ".divide-dashed > * + *" [ borderStyle (BorderStyleRaw "dashed") ]
    , rule ".divide-dotted > * + *" [ borderStyle (BorderStyleRaw "dotted") ]
    , rule ".divide-double > * + *" [ borderStyle (BorderStyleRaw "double") ]
    , rule ".divide-none > * + *" [ borderStyle (BorderStyleRaw "none") ]
    ]

-- ============================================================
-- Ring
-- ============================================================
ringRules =
    [ rule ".ring" [ property "box-shadow" "0 0 0 3px rgba(59, 130, 246, 0.5)" ]

    -- Ring Offset
    , rule ".ring-0" [ property "box-shadow" "0 0 0 0px transparent" ]

    -- Ring Color
    , rule ".ring-1"
        [ property "box-shadow" "0 0 0 1px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-2"
        [ property "box-shadow" "0 0 0 2px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-4"
        [ property "box-shadow" "0 0 0 4px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-8"
        [ property "box-shadow" "0 0 0 8px rgba(59, 130, 246, 0.5)" ]
    , rule ".ring-inset" [ property "--tw-ring-inset" "inset" ]
    , rule ".ring-offset-0"
        [ property "box-shadow"
            "0 0 0 0px #fff, 0 0 0 3px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-1"
        [ property "box-shadow"
            "0 0 0 1px #fff, 0 0 0 4px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-2"
        [ property "box-shadow"
            "0 0 0 2px #fff, 0 0 0 5px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-4"
        [ property "box-shadow"
            "0 0 0 4px #fff, 0 0 0 7px rgba(59, 130, 246, 0.5)"
        ]
    , rule ".ring-offset-white" [ property "--tw-ring-offset-color" "#ffffff" ]
    , rule ".ring-offset-gray-50"
        [ property "--tw-ring-offset-color" "#f9fafb" ]
    , rule ".ring-transparent" [ property "--tw-ring-color" "transparent" ]
    , rule ".ring-black" [ property "--tw-ring-color" "#000000" ]
    , rule ".ring-white" [ property "--tw-ring-color" "#ffffff" ]
    , rule ".ring-gray-200" [ property "--tw-ring-color" "#e5e7eb" ]
    , rule ".ring-gray-300" [ property "--tw-ring-color" "#d1d5db" ]
    , rule ".ring-gray-500" [ property "--tw-ring-color" "#6b7280" ]
    , rule ".ring-blue-500" [ property "--tw-ring-color" "#3b82f6" ]
    , rule ".ring-blue-600" [ property "--tw-ring-color" "#2563eb" ]
    , rule ".ring-indigo-500" [ property "--tw-ring-color" "#6366f1" ]
    , rule ".ring-red-500" [ property "--tw-ring-color" "#ef4444" ]
    , rule ".ring-green-500" [ property "--tw-ring-color" "#22c55e" ]
    , rule ".ring-purple-500" [ property "--tw-ring-color" "#a855f7" ]
    , rule ".ring-pink-500" [ property "--tw-ring-color" "#ec4899" ]
    ]

-- ============================================================
-- Table
-- ============================================================
tableRules =
    [ rule ".table-auto" [ property "table-layout" "auto" ]
    , rule ".table-fixed" [ property "table-layout" "fixed" ]
    , rule ".caption-top" [ property "caption-side" "top" ]
    , rule ".caption-bottom" [ property "caption-side" "bottom" ]
    ]

-- ============================================================
-- Accessibility
-- ============================================================
accessibilityRules =
    [ rule ".sr-only"
        [ position (PositionRaw "absolute")
        , width (lengthRaw "1px")
        , height (lengthRaw "1px")
        , padding (lengthRaw "0")
        , margin (lengthRaw "-1px")
        , overflow (OverflowRaw "hidden")
        , property "clip" "rect(0, 0, 0, 0)"
        , property "white-space" "nowrap"
        , borderWidth (lengthRaw "0")
        ]
    , rule ".not-sr-only"
        [ position (PositionRaw "static")
        , width (lengthRaw "auto")
        , height (lengthRaw "auto")
        , padding (lengthRaw "0")
        , margin (lengthRaw "0")
        , overflow (OverflowRaw "visible")
        , property "clip" "auto"
        , property "white-space" "normal"
        ]
    , rule ".forced-color-adjust-auto" [ property "forced-color-adjust" "auto" ]
    , rule ".forced-color-adjust-none" [ property "forced-color-adjust" "none" ]
    ]

-- ============================================================
-- SVG
-- ============================================================
svgRules =
    [ rule ".fill-current" [ property "fill" "currentColor" ]
    , rule ".fill-none" [ property "fill" "none" ]
    , rule ".fill-black" [ property "fill" "#000000" ]
    , rule ".fill-white" [ property "fill" "#ffffff" ]
    , rule ".fill-red-500" [ property "fill" "#ef4444" ]
    , rule ".fill-blue-500" [ property "fill" "#3b82f6" ]
    , rule ".fill-green-500" [ property "fill" "#22c55e" ]
    , rule ".fill-gray-500" [ property "fill" "#6b7280" ]
    , rule ".stroke-current" [ property "stroke" "currentColor" ]
    , rule ".stroke-none" [ property "stroke" "none" ]
    , rule ".stroke-black" [ property "stroke" "#000000" ]
    , rule ".stroke-white" [ property "stroke" "#ffffff" ]
    , rule ".stroke-gray-300" [ property "stroke" "#d1d5db" ]
    , rule ".stroke-gray-500" [ property "stroke" "#6b7280" ]
    , rule ".stroke-blue-500" [ property "stroke" "#3b82f6" ]
    , rule ".stroke-0" [ property "stroke-width" "0" ]
    , rule ".stroke-1" [ property "stroke-width" "1" ]
    , rule ".stroke-2" [ property "stroke-width" "2" ]
    ]

-- ============================================================
-- Interactivity: cursor, pointer-events, user-select, resize, scroll, touch, appearance
-- ============================================================
interactivityRules =
    [ rule ".cursor-auto" [ cursor (CursorRaw "auto") ]

    -- Pointer Events
    , rule ".cursor-default" [ cursor (CursorRaw "default") ]

    -- User Select
    , rule ".cursor-pointer" [ cursor (CursorRaw "pointer") ]

    -- Resize
    , rule ".cursor-wait" [ cursor (CursorRaw "wait") ]

    -- Scroll Behavior
    , rule ".cursor-text" [ cursor (CursorRaw "text") ]

    -- Scroll Snap Type
    , rule ".cursor-move" [ cursor (CursorRaw "move") ]

    -- Scroll Snap Align
    , rule ".cursor-help" [ cursor (CursorRaw "help") ]

    -- Scroll Margin
    , rule ".cursor-not-allowed" [ cursor (CursorRaw "not-allowed") ]

    -- Scroll Padding
    , rule ".cursor-none" [ cursor (CursorRaw "none") ]

    -- Touch Action
    , rule ".cursor-context-menu" [ cursor (CursorRaw "context-menu") ]

    -- Appearance
    , rule ".cursor-progress" [ cursor (CursorRaw "progress") ]

    -- Caret Color
    , rule ".cursor-cell" [ cursor (CursorRaw "cell") ]

    -- Accent Color
    , rule ".cursor-crosshair" [ cursor (CursorRaw "crosshair") ]
    , rule ".cursor-vertical-text" [ cursor (CursorRaw "vertical-text") ]
    , rule ".cursor-alias" [ cursor (CursorRaw "alias") ]
    , rule ".cursor-copy" [ cursor (CursorRaw "copy") ]
    , rule ".cursor-no-drop" [ cursor (CursorRaw "no-drop") ]
    , rule ".cursor-grab" [ cursor (CursorRaw "grab") ]
    , rule ".cursor-grabbing" [ cursor (CursorRaw "grabbing") ]
    , rule ".cursor-all-scroll" [ cursor (CursorRaw "all-scroll") ]
    , rule ".cursor-col-resize" [ cursor (CursorRaw "col-resize") ]
    , rule ".cursor-row-resize" [ cursor (CursorRaw "row-resize") ]
    , rule ".cursor-zoom-in" [ cursor (CursorRaw "zoom-in") ]
    , rule ".cursor-zoom-out" [ cursor (CursorRaw "zoom-out") ]
    , rule ".pointer-events-none" [ property "pointer-events" "none" ]
    , rule ".pointer-events-auto" [ property "pointer-events" "auto" ]
    , rule ".select-none" [ property "user-select" "none" ]
    , rule ".select-text" [ property "user-select" "text" ]
    , rule ".select-all" [ property "user-select" "all" ]
    , rule ".select-auto" [ property "user-select" "auto" ]
    , rule ".resize-none" [ property "resize" "none" ]
    , rule ".resize-y" [ property "resize" "vertical" ]
    , rule ".resize-x" [ property "resize" "horizontal" ]
    , rule ".resize" [ property "resize" "both" ]
    , rule ".scroll-auto" [ property "scroll-behavior" "auto" ]
    , rule ".scroll-smooth" [ property "scroll-behavior" "smooth" ]
    , rule ".snap-none" [ property "scroll-snap-type" "none" ]
    , rule ".snap-x" [ property "scroll-snap-type" "x mandatory" ]
    , rule ".snap-y" [ property "scroll-snap-type" "y mandatory" ]
    , rule ".snap-both" [ property "scroll-snap-type" "both mandatory" ]
    , rule ".snap-start" [ property "scroll-snap-align" "start" ]
    , rule ".snap-end" [ property "scroll-snap-align" "end" ]
    , rule ".snap-center" [ property "scroll-snap-align" "center" ]
    , rule ".snap-align-none" [ property "scroll-snap-align" "none" ]
    , rule ".scroll-m-0" [ property "scroll-margin" "0" ]
    , rule ".scroll-m-4" [ property "scroll-margin" "1rem" ]
    , rule ".scroll-m-8" [ property "scroll-margin" "2rem" ]
    , rule ".scroll-mt-0" [ property "scroll-margin-top" "0" ]
    , rule ".scroll-mt-4" [ property "scroll-margin-top" "1rem" ]
    , rule ".scroll-mt-8" [ property "scroll-margin-top" "2rem" ]
    , rule ".scroll-mt-16" [ property "scroll-margin-top" "4rem" ]
    , rule ".scroll-mt-20" [ property "scroll-margin-top" "5rem" ]
    , rule ".scroll-p-0" [ property "scroll-padding" "0" ]
    , rule ".scroll-p-4" [ property "scroll-padding" "1rem" ]
    , rule ".scroll-p-8" [ property "scroll-padding" "2rem" ]
    , rule ".scroll-pt-0" [ property "scroll-padding-top" "0" ]
    , rule ".scroll-pt-4" [ property "scroll-padding-top" "1rem" ]
    , rule ".touch-auto" [ property "touch-action" "auto" ]
    , rule ".touch-none" [ property "touch-action" "none" ]
    , rule ".touch-pan-x" [ property "touch-action" "pan-x" ]
    , rule ".touch-pan-y" [ property "touch-action" "pan-y" ]
    , rule ".touch-pinch-zoom" [ property "touch-action" "pinch-zoom" ]
    , rule ".touch-manipulation" [ property "touch-action" "manipulation" ]
    , rule ".appearance-none" [ property "appearance" "none" ]
    , rule ".appearance-auto" [ property "appearance" "auto" ]
    , rule ".caret-transparent" [ property "caret-color" "transparent" ]
    , rule ".caret-black" [ property "caret-color" "#000000" ]
    , rule ".caret-white" [ property "caret-color" "#ffffff" ]
    , rule ".caret-blue-500" [ property "caret-color" "#3b82f6" ]
    , rule ".caret-red-500" [ property "caret-color" "#ef4444" ]
    , rule ".accent-auto" [ property "accent-color" "auto" ]
    , rule ".accent-blue-500" [ property "accent-color" "#3b82f6" ]
    , rule ".accent-indigo-500" [ property "accent-color" "#6366f1" ]
    , rule ".accent-purple-500" [ property "accent-color" "#a855f7" ]
    , rule ".accent-pink-500" [ property "accent-color" "#ec4899" ]
    , rule ".accent-red-500" [ property "accent-color" "#ef4444" ]
    , rule ".accent-green-500" [ property "accent-color" "#22c55e" ]
    ]

-- ============================================================
-- State variants: hover, focus, active, disabled, first, last, placeholder, focus-visible, group-hover
-- ============================================================
stateRules =
    [ rule ".hover\\:bg-transparent:hover" [ backgroundColor (colorRaw "transparent") ]

    -- Hover: text colors
    , rule ".hover\\:bg-black:hover" [ backgroundColor (colorRaw "#000000") ]

    -- Hover: text decoration
    , rule ".hover\\:bg-white:hover" [ backgroundColor (colorRaw "#ffffff") ]

    -- Hover: opacity
    , rule ".hover\\:bg-slate-50:hover" [ backgroundColor (colorRaw "#f8fafc") ]

    -- Hover: shadow
    , rule ".hover\\:bg-slate-100:hover" [ backgroundColor (colorRaw "#f1f5f9") ]

    -- Hover: scale
    , rule ".hover\\:bg-slate-200:hover" [ backgroundColor (colorRaw "#e2e8f0") ]

    -- Hover: ring
    , rule ".hover\\:bg-slate-700:hover" [ backgroundColor (colorRaw "#334155") ]

    -- Hover: border color
    , rule ".hover\\:bg-slate-800:hover" [ backgroundColor (colorRaw "#1e293b") ]

    -- Hover: translate
    , rule ".hover\\:bg-gray-50:hover" [ backgroundColor (colorRaw "#f9fafb") ]

    -- Hover: rotate
    , rule ".hover\\:bg-gray-100:hover" [ backgroundColor (colorRaw "#f3f4f6") ]

    -- Hover: brightness
    , rule ".hover\\:bg-gray-200:hover" [ backgroundColor (colorRaw "#e5e7eb") ]

    -- Focus: outline
    , rule ".hover\\:bg-gray-300:hover" [ backgroundColor (colorRaw "#d1d5db") ]

    -- Focus: ring
    , rule ".hover\\:bg-gray-600:hover" [ backgroundColor (colorRaw "#4b5563") ]

    -- Focus: ring colors
    , rule ".hover\\:bg-gray-700:hover" [ backgroundColor (colorRaw "#374151") ]

    -- Focus: border color
    , rule ".hover\\:bg-gray-800:hover" [ backgroundColor (colorRaw "#1f2937") ]

    -- Focus: bg
    , rule ".hover\\:bg-gray-900:hover" [ backgroundColor (colorRaw "#111827") ]

    -- Focus: text
    , rule ".hover\\:bg-red-50:hover" [ backgroundColor (colorRaw "#fef2f2") ]

    -- Focus-visible
    , rule ".hover\\:bg-red-100:hover" [ backgroundColor (colorRaw "#fee2e2") ]

    -- Focus-within
    , rule ".hover\\:bg-red-500:hover" [ backgroundColor (colorRaw "#ef4444") ]

    -- Active
    , rule ".hover\\:bg-red-600:hover" [ backgroundColor (colorRaw "#dc2626") ]

    -- Disabled
