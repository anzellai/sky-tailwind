    , rule ".-mb-2" [ marginBottom "-0.5rem" ]
    , rule ".-ml-1" [ marginLeft "-0.25rem" ]
    , rule ".-ml-2" [ marginLeft "-0.5rem" ]
    , rule ".-mr-1" [ marginRight "-0.25rem" ]
    , rule ".-mr-2" [ marginRight "-0.5rem" ]
    , rule ".-mx-4" [ marginLeft "-1rem" , marginRight "-1rem" ]
    , rule ".gap-0" [ gap "0" ]
