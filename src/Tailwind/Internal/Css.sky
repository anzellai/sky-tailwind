-- ============================================================
-- Layout: display, position, z-index, overflow, float, clear, visibility, isolation
-- ============================================================
layoutRules =
    [ rule ".block" [ display (DisplayRaw "block") ]

    -- Position
    , rule ".inline-block" [ display (DisplayRaw "inline-block") ]

    -- Inset (top/right/bottom/left)
    , rule ".inline" [ display (DisplayRaw "inline") ]

    -- Z-Index
    , rule ".flex" [ display (DisplayRaw "flex") ]

    -- Overflow
    , rule ".inline-flex" [ display (DisplayRaw "inline-flex") ]

    -- Overscroll
    , rule ".grid" [ display (DisplayRaw "grid") ]

    -- Float
    , rule ".inline-grid" [ display (DisplayRaw "inline-grid") ]

    -- Clear
    , rule ".hidden" [ display (DisplayRaw "none") ]

    -- Visibility
    , rule ".contents" [ display (DisplayRaw "contents") ]

    -- Isolation
    , rule ".flow-root" [ display (DisplayRaw "flow-root") ]

    -- Columns
    , rule ".table" [ display (DisplayRaw "table") ]

    -- Break
    , rule ".table-caption" [ display (DisplayRaw "table-caption") ]
    , rule ".table-row" [ display (DisplayRaw "table-row") ]
    , rule ".table-cell" [ display (DisplayRaw "table-cell") ]
    , rule ".table-column" [ display (DisplayRaw "table-column") ]
    , rule ".table-column-group" [ display (DisplayRaw "table-column-group") ]
    , rule ".table-footer-group" [ display (DisplayRaw "table-footer-group") ]
    , rule ".table-header-group" [ display (DisplayRaw "table-header-group") ]
    , rule ".table-row-group" [ display (DisplayRaw "table-row-group") ]
    , rule ".static" [ position (PositionRaw "static") ]
    , rule ".relative" [ position (PositionRaw "relative") ]
    , rule ".absolute" [ position (PositionRaw "absolute") ]
    , rule ".fixed" [ position (PositionRaw "fixed") ]
    , rule ".sticky" [ position (PositionRaw "sticky") ]
    , rule ".inset-0" [ top (lengthRaw "0") , right (lengthRaw "0") , bottom (lengthRaw "0") , left (lengthRaw "0") ]
    , rule ".inset-1"
        [ top (lengthRaw "0.25rem") , right (lengthRaw "0.25rem") , bottom (lengthRaw "0.25rem") , left (lengthRaw "0.25rem") ]
    , rule ".inset-2"
        [ top (lengthRaw "0.5rem") , right (lengthRaw "0.5rem") , bottom (lengthRaw "0.5rem") , left (lengthRaw "0.5rem") ]
    , rule ".inset-4"
        [ top (lengthRaw "1rem") , right (lengthRaw "1rem") , bottom (lengthRaw "1rem") , left (lengthRaw "1rem") ]
    , rule ".inset-auto"
        [ top (lengthRaw "auto") , right (lengthRaw "auto") , bottom (lengthRaw "auto") , left (lengthRaw "auto") ]
    , rule ".inset-x-0" [ left (lengthRaw "0") , right (lengthRaw "0") ]
    , rule ".inset-x-auto" [ left (lengthRaw "auto") , right (lengthRaw "auto") ]
    , rule ".inset-y-0" [ top (lengthRaw "0") , bottom (lengthRaw "0") ]
    , rule ".inset-y-auto" [ top (lengthRaw "auto") , bottom (lengthRaw "auto") ]
    , rule ".top-0" [ top (lengthRaw "0") ]
    , rule ".top-1" [ top (lengthRaw "0.25rem") ]
    , rule ".top-2" [ top (lengthRaw "0.5rem") ]
    , rule ".top-3" [ top (lengthRaw "0.75rem") ]
    , rule ".top-4" [ top (lengthRaw "1rem") ]
    , rule ".top-6" [ top (lengthRaw "1.5rem") ]
    , rule ".top-8" [ top (lengthRaw "2rem") ]
    , rule ".top-12" [ top (lengthRaw "3rem") ]
    , rule ".top-16" [ top (lengthRaw "4rem") ]
    , rule ".top-auto" [ top (lengthRaw "auto") ]
    , rule ".top-full" [ top (lengthRaw "100%") ]
    , rule ".top-1\\/2" [ top (lengthRaw "50%") ]
    , rule ".-top-1" [ top (lengthRaw "-0.25rem") ]
    , rule ".-top-2" [ top (lengthRaw "-0.5rem") ]
    , rule ".-top-4" [ top (lengthRaw "-1rem") ]
    , rule ".right-0" [ right (lengthRaw "0") ]
    , rule ".right-1" [ right (lengthRaw "0.25rem") ]
    , rule ".right-2" [ right (lengthRaw "0.5rem") ]
    , rule ".right-4" [ right (lengthRaw "1rem") ]
    , rule ".right-6" [ right (lengthRaw "1.5rem") ]
    , rule ".right-8" [ right (lengthRaw "2rem") ]
    , rule ".right-auto" [ right (lengthRaw "auto") ]
    , rule ".bottom-0" [ bottom (lengthRaw "0") ]
    , rule ".bottom-1" [ bottom (lengthRaw "0.25rem") ]
    , rule ".bottom-2" [ bottom (lengthRaw "0.5rem") ]
    , rule ".bottom-4" [ bottom (lengthRaw "1rem") ]
    , rule ".bottom-6" [ bottom (lengthRaw "1.5rem") ]
    , rule ".bottom-8" [ bottom (lengthRaw "2rem") ]
    , rule ".bottom-auto" [ bottom (lengthRaw "auto") ]
    , rule ".left-0" [ left (lengthRaw "0") ]
    , rule ".left-1" [ left (lengthRaw "0.25rem") ]
    , rule ".left-2" [ left (lengthRaw "0.5rem") ]
    , rule ".left-4" [ left (lengthRaw "1rem") ]
    , rule ".left-6" [ left (lengthRaw "1.5rem") ]
    , rule ".left-8" [ left (lengthRaw "2rem") ]
    , rule ".left-auto" [ left (lengthRaw "auto") ]
    , rule ".left-full" [ left (lengthRaw "100%") ]
    , rule ".left-1\\/2" [ left (lengthRaw "50%") ]
    , rule ".z-0" [ property "z-index" "0" ]
    , rule ".z-10" [ property "z-index" "10" ]
    , rule ".z-20" [ property "z-index" "20" ]
    , rule ".z-30" [ property "z-index" "30" ]
    , rule ".z-40" [ property "z-index" "40" ]
    , rule ".z-50" [ property "z-index" "50" ]
    , rule ".z-auto" [ property "z-index" "auto" ]
    , rule ".-z-10" [ property "z-index" "-10" ]
    , rule ".overflow-auto" [ overflow (OverflowRaw "auto") ]
    , rule ".overflow-hidden" [ overflow (OverflowRaw "hidden") ]
    , rule ".overflow-clip" [ overflow (OverflowRaw "clip") ]
    , rule ".overflow-visible" [ overflow (OverflowRaw "visible") ]
    , rule ".overflow-scroll" [ overflow (OverflowRaw "scroll") ]
    , rule ".overflow-x-auto" [ property "overflow-x" "auto" ]
    , rule ".overflow-x-hidden" [ property "overflow-x" "hidden" ]
    , rule ".overflow-x-clip" [ property "overflow-x" "clip" ]
    , rule ".overflow-x-scroll" [ property "overflow-x" "scroll" ]
    , rule ".overflow-y-auto" [ property "overflow-y" "auto" ]
    , rule ".overflow-y-hidden" [ property "overflow-y" "hidden" ]
    , rule ".overflow-y-clip" [ property "overflow-y" "clip" ]
    , rule ".overflow-y-scroll" [ property "overflow-y" "scroll" ]
    , rule ".overscroll-auto" [ property "overscroll-behavior" "auto" ]
    , rule ".overscroll-contain" [ property "overscroll-behavior" "contain" ]
    , rule ".overscroll-none" [ property "overscroll-behavior" "none" ]
    , rule ".float-left" [ float "left" ]
    , rule ".float-right" [ float "right" ]
    , rule ".float-none" [ float "none" ]
    , rule ".clear-left" [ clear "left" ]
    , rule ".clear-right" [ clear "right" ]
    , rule ".clear-both" [ clear "both" ]
    , rule ".clear-none" [ clear "none" ]
    , rule ".visible" [ visibility "visible" ]
    , rule ".invisible" [ visibility "hidden" ]
    , rule ".collapse" [ visibility "collapse" ]
    , rule ".isolate" [ property "isolation" "isolate" ]
    , rule ".isolation-auto" [ property "isolation" "auto" ]
    , rule ".columns-1" [ property "columns" "1" ]
    , rule ".columns-2" [ property "columns" "2" ]
    , rule ".columns-3" [ property "columns" "3" ]
    , rule ".columns-4" [ property "columns" "4" ]
    , rule ".columns-auto" [ property "columns" "auto" ]
    , rule ".break-after-auto" [ property "break-after" "auto" ]
    , rule ".break-after-avoid" [ property "break-after" "avoid" ]
    , rule ".break-before-auto" [ property "break-before" "auto" ]
    , rule ".break-before-avoid" [ property "break-before" "avoid" ]
    , rule ".break-inside-auto" [ property "break-inside" "auto" ]
    , rule ".break-inside-avoid" [ property "break-inside" "avoid" ]
    ]

-- ============================================================
-- Flexbox
-- ============================================================
flexRules =
    [ rule ".flex-row" [ flexDirection (FlexDirectionRaw "row") ]

    -- Flex Wrap
    , rule ".flex-row-reverse" [ flexDirection (FlexDirectionRaw "row-reverse") ]

    -- Justify Content
    , rule ".flex-col" [ flexDirection (FlexDirectionRaw "column") ]

    -- Justify Items
    , rule ".flex-col-reverse" [ flexDirection (FlexDirectionRaw "column-reverse") ]

    -- Justify Self
    , rule ".flex-wrap" [ flexWrap (FlexWrapRaw "wrap") ]

    -- Align Items
    , rule ".flex-wrap-reverse" [ flexWrap (FlexWrapRaw "wrap-reverse") ]

    -- Align Self
    , rule ".flex-nowrap" [ flexWrap (FlexWrapRaw "nowrap") ]

    -- Align Content
    , rule ".justify-start" [ justifyContent (AlignRaw "flex-start") ]

    -- Flex shorthand
    , rule ".justify-end" [ justifyContent (AlignRaw "flex-end") ]

    -- Flex Grow
    , rule ".justify-center" [ justifyContent (AlignRaw "center") ]

    -- Flex Shrink
    , rule ".justify-between" [ justifyContent (AlignRaw "space-between") ]

    -- Flex Basis
    , rule ".justify-around" [ justifyContent (AlignRaw "space-around") ]

    -- Order
    , rule ".justify-evenly" [ justifyContent (AlignRaw "space-evenly") ]
    , rule ".justify-stretch" [ justifyContent (AlignRaw "stretch") ]
    , rule ".justify-normal" [ justifyContent (AlignRaw "normal") ]
    , rule ".justify-items-start" [ property "justify-items" "start" ]
    , rule ".justify-items-end" [ property "justify-items" "end" ]
    , rule ".justify-items-center" [ property "justify-items" "center" ]
    , rule ".justify-items-stretch" [ property "justify-items" "stretch" ]
    , rule ".justify-self-auto" [ property "justify-self" "auto" ]
    , rule ".justify-self-start" [ property "justify-self" "start" ]
    , rule ".justify-self-end" [ property "justify-self" "end" ]
    , rule ".justify-self-center" [ property "justify-self" "center" ]
    , rule ".justify-self-stretch" [ property "justify-self" "stretch" ]
    , rule ".items-start" [ alignItems (AlignRaw "flex-start") ]
    , rule ".items-end" [ alignItems (AlignRaw "flex-end") ]
    , rule ".items-center" [ alignItems (AlignRaw "center") ]
    , rule ".items-baseline" [ alignItems (AlignRaw "baseline") ]
    , rule ".items-stretch" [ alignItems (AlignRaw "stretch") ]
    , rule ".self-auto" [ property "align-self" "auto" ]
