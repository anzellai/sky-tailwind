-- ============================================================
-- State variants: hover, focus, active, disabled, first, last, placeholder, focus-visible, group-hover
-- ============================================================
stateRules =
    [ rule ".hover\\:bg-transparent:hover" [ backgroundColor "transparent" ]

    -- Hover: text colors
    , rule ".hover\\:bg-black:hover" [ backgroundColor "#000000" ]

    -- Hover: text decoration
    , rule ".hover\\:bg-white:hover" [ backgroundColor "#ffffff" ]

    -- Hover: opacity
    , rule ".hover\\:bg-slate-50:hover" [ backgroundColor "#f8fafc" ]

    -- Hover: shadow
    , rule ".hover\\:bg-slate-100:hover" [ backgroundColor "#f1f5f9" ]

    -- Hover: scale
