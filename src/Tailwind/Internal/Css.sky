-- ============================================================
-- Animation
-- ============================================================
animationRules =
    [ keyframes "spin" [ frame "to" [ "transform:rotate(360deg)" ] ]
    , keyframes "ping"
        [ frame "75%, 100%" [ "transform:scale(2)" , "opacity:0" ] ]
    , keyframes "pulse" [ frame "50%" [ "opacity:.5" ] ]
    , keyframes "bounce"
        [ frame "0%, 100%"
            [ "transform:translateY(-25%)"
            , "animation-timing-function:cubic-bezier(0.8, 0, 1, 1)"
            ]
        , frame "50%"
            [ "transform:none"
            , "animation-timing-function:cubic-bezier(0, 0, 0.2, 1)"
            ]
        ]
    , rule ".animate-none" [ property "animation" "none" ]
    , rule ".animate-spin" [ property "animation" "spin 1s linear infinite" ]
    , rule ".animate-ping"
        [ property "animation" "ping 1s cubic-bezier(0, 0, 0.2, 1) infinite" ]
    , rule ".animate-pulse"
        [ property "animation" "pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite"
        ]
    , rule ".animate-bounce" [ property "animation" "bounce 1s infinite" ]
    ]

-- ============================================================
-- Transforms: scale, rotate, translate, skew, origin
-- ============================================================
transformsRules =
    [ rule ".scale-0" [ transform "scale(0)" ]

    -- Rotate
    , rule ".scale-50" [ transform "scale(.5)" ]

    -- Translate X
    , rule ".scale-75" [ transform "scale(.75)" ]

    -- Translate Y
    , rule ".scale-90" [ transform "scale(.9)" ]

    -- Skew
    , rule ".scale-95" [ transform "scale(.95)" ]

    -- Transform Origin
    , rule ".scale-100" [ transform "scale(1)" ]
    , rule ".scale-105" [ transform "scale(1.05)" ]
    , rule ".scale-110" [ transform "scale(1.1)" ]
    , rule ".scale-125" [ transform "scale(1.25)" ]
    , rule ".scale-150" [ transform "scale(1.5)" ]
    , rule ".scale-x-0" [ transform "scaleX(0)" ]
    , rule ".scale-x-50" [ transform "scaleX(.5)" ]
    , rule ".scale-x-100" [ transform "scaleX(1)" ]
    , rule ".scale-y-0" [ transform "scaleY(0)" ]
    , rule ".scale-y-50" [ transform "scaleY(.5)" ]
    , rule ".scale-y-100" [ transform "scaleY(1)" ]
    , rule ".rotate-0" [ transform "rotate(0deg)" ]
