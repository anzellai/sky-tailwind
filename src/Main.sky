                [ text
                    "This counter is built entirely with Sky-Tailwind utilities. Try it!"
                ]
            , div
                [ tw
                    [ Tw.bgGray50
                    , Tw.roundedXl
                    , Tw.p8
                    , Tw.maxW2xl
                    , Tw.mxAuto
                    ]
                ]
