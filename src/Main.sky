refCard title_ items =
    div [ tw [ bgWhite, roundedLg, shadow, p6 ] ]
        [ h3 [ tw [ fontSemibold, textGray900, mb4 ] ]
            [ text title_ ]
        , ul [ tw [ textSm, fontMono, textGray600 ] ]
            (items
                |> List.map (\item ->
                    li [ tw [ mb2, leadingRelaxed ] ] [ text item ]
                )
            )
        ]


-- ============================================================
-- GETTING STARTED PAGE
-- ============================================================

gettingStartedPage =
    div [ tw [ maxW4xl, mxAuto, px6, py12 ] ]
        [ h1 [ tw [ text3xl, fontBold, textGray900, mb8 ] ]
            [ text "Getting Started" ]

        -- Step 1: Install
        , section_ "1. Add to your project"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Add sky-tailwind as a dependency in your sky.toml:" ]
            , codeBlock "[dependencies]\n\"github.com/anzellai/sky-tailwind\" = \"latest\""
            ]

        -- Step 2: Import
        , section_ "2. Import the modules you need"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Each category has its own module. Import what you use:" ]
            , codeBlock "import SkyTailwind exposing (styles, tw)\nimport SkyTailwind.Spacing exposing (p4, mt2, gap4)\nimport SkyTailwind.Typography exposing (textLg, fontBold, textWhite)\nimport SkyTailwind.Background exposing (bgBlue500)\nimport SkyTailwind.Border exposing (roundedLg)\nimport SkyTailwind.Effects exposing (shadowMd)\nimport SkyTailwind.State exposing (hover)\nimport SkyTailwind.Responsive exposing (md, lg)"
            , p [ tw [ textGray600, mt4, mb4, leadingRelaxed ] ]
                [ text "Or import everything from a module with exposing (..) for rapid prototyping:" ]
            , codeBlock "import SkyTailwind.Spacing exposing (..)\nimport SkyTailwind.Typography exposing (..)"
            ]

        -- Step 3: Add styles
        , section_ "3. Add the styles node to your view"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Place the styles VNode once in your top-level view. This injects all the CSS rules:" ]
            , codeBlock "view model =\n    div []\n        [ styles    -- inject CSS, place once at top level\n        , h1 [] [ text \"Hello!\" ]\n        ]"
            ]

        -- Step 4: Use tw
        , section_ "4. Compose utilities with tw"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "The tw function merges a list of utilities into a single class attribute:" ]
            , codeBlock "button\n    [ tw [ bgBlue500, textWhite, fontBold, py2, px4, roundedLg ] ]\n    [ text \"Click me\" ]"
            , p [ tw [ textGray600, mt4, mb4, leadingRelaxed ] ]
                [ text "For a single utility, use it directly as an attribute:" ]
            , codeBlock "div [ p4 ] [ text \"Just padding\" ]"
            ]

        -- Step 5: Responsive
        , section_ "5. Responsive design"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Wrap any utility with a breakpoint function. The variant functions (sm, md, lg, xl, xxl) take a utility and return a responsive version:" ]
            , codeBlock "div [ tw [ p4, md p8, lg p12 ] ]\n    [ text \"Padding grows with screen size\" ]\n\ndiv [ tw [ gridCols1, md gridCols2, lg gridCols4, gap4 ] ]\n    [ text \"Responsive grid\" ]"
            , div [ tw [ bgBlue50, roundedLg, p4, mt4, mb4 ] ]
                [ p [ tw [ textSm, textBlue700 ] ]
                    [ text "Breakpoints: sm = 640px, md = 768px, lg = 1024px, xl = 1280px, xxl = 1536px" ]
                ]
            ]

        -- Step 6: State
        , section_ "6. Interactive states"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Wrap a utility with hover, focus, active, or disabled to apply it on that state:" ]
            , codeBlock "button\n    [ tw [ bgBlue500\n         , hover bgBlue700\n         , focus ring2\n         , active scale95\n         , transitionAll, duration200\n         ]\n    ]\n    [ text \"Interactive button\" ]"
            , p [ tw [ textGray600, mt4, mb4, leadingRelaxed ] ]
                [ text "This works because hover, focus, etc. are higher-order functions that prefix the class name." ]
            ]

        -- Step 7: Conditional
        , section_ "7. Conditional styling"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Since tw takes a List, conditional styling is just list manipulation:" ]
            , codeBlock "div [ tw ([ p4, rounded, textWhite ]\n    ++ (if model.active\n        then [ bgGreen500 ]\n        else [ bgGray400 ])\n    ) ]\n    [ text \"Conditional background\" ]"
            ]

        -- Step 8: twWith
        , section_ "8. Mixing with custom classes"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Use twWith to merge sky-tailwind utilities with additional custom class names:" ]
            , codeBlock "div [ twWith \"my-custom-class animated\" [ p4, bgWhite, roundedLg ] ]\n    [ text \"Sky-Tailwind + custom\" ]"
            ]

        -- Step 9: Component patterns
        , section_ "9. Building reusable components"
            [ p [ tw [ textGray600, mb4, leadingRelaxed ] ]
                [ text "Extract styled elements into functions — this is the Sky-Tailwind way of building a design system:" ]
            , codeBlock "-- Define a reusable button component\nprimaryBtn label msg =\n    button\n        [ tw [ bgBlue600, hover bgBlue700, textWhite, fontSemibold\n             , py2, px6, roundedLg, transitionColors, duration200\n             , cursorPointer\n             ]\n        , onClick msg\n        ]\n        [ text label ]\n\n\n-- Define a card component\ncard title_ body =\n    div [ tw [ bgWhite, roundedXl, shadowMd, p6\n             , hover shadowLg, transitionAll, duration300\n             ]\n        ]\n        [ h3 [ tw [ textLg, fontSemibold, mb2 ] ] [ text title_ ]\n        , p [ tw [ textSm, textGray600 ] ] [ text body ]\n        ]\n\n\n-- Use them in your view\nview model =\n    div [ tw [ grid, md gridCols3, gap6, p8 ] ]\n        [ card \"Title\" \"Description\"\n        , card \"Title\" \"Description\"\n        , primaryBtn \"Save\" \"Save\"\n        ]"
            ]
        ]


section_ title_ content =
    div [ tw [ mb12 ] ]
        ([ h2 [ tw [ text2xl, fontSemibold, textGray900, mb4, mt4 ] ]
            [ text title_ ]
        ] ++ content)


codeBlock code =
    pre [ tw [ bgGray900, textGray100, p6, roundedLg, overflowXAuto
             , textSm, fontMono, leadingRelaxed, mt4, mb4
             ]
        ]
        [ codeNode [] [ text code ] ]


