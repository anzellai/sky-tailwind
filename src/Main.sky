module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Sky.Core.List as List
import Sky.Core.String as String
import Std.Html exposing (..)
import Std.Html.Attributes exposing (..)
import Std.Live exposing (app, route)
import Std.Live.Events exposing (onClick)
import Std.Cmd as Cmd
import Std.Sub as Sub
import Tailwind as Tw exposing (styles, tw)

type Page
    = HomePage
    | GettingStartedPage
    | ComponentsPage

type alias Model =
    { page : Page , count : Int , navOpen : Bool }

type Msg
    = Navigate Page
    | Increment
    | Decrement
    | ToggleNav

init _ =
    ( { page = HomePage , count = 0 , navOpen = False } , Cmd.none )

update msg model =
    case msg of
        Navigate p ->
            ( { model | page = p , navOpen = False } , Cmd.none )
        
        Increment ->
            ( { model | count = model.count + 1 } , Cmd.none )
        
        Decrement ->
            ( { model | count = model.count - 1 } , Cmd.none )
        
        ToggleNav ->
            ( { model | navOpen = not model.navOpen } , Cmd.none )

subscriptions _ =
    Sub.none

viewPage model =
    case model.page of
        HomePage ->
            homeView model
        
        GettingStartedPage ->
            gettingStartedView
        
        ComponentsPage ->
            componentsView model

view model =
    div [ tw [ Tw.minHScreen , Tw.bgGray50 , Tw.fontSans ] ]
        [ styles , navbar model , viewPage model , footer_ ]

navbar model =
    nav [ tw [ Tw.bgWhite , Tw.shadowSm , Tw.sticky , Tw.top0 , Tw.z50 ] ]
        [ div [ tw [ Tw.maxW6xl , Tw.mxAuto , Tw.px4 ] ]
            [ div
                [ tw [ Tw.flex , Tw.justifyBetween , Tw.itemsCenter , Tw.h16 ] ]
                [ a [ href "/" , attribute "sky-nav" "" ]
                    [ span [ tw [ Tw.text2xl , Tw.fontBold , Tw.textBlue600 ] ]
                        [ text "Sky" ]
                    , span [ tw [ Tw.text2xl , Tw.fontLight , Tw.textGray400 ] ]
                        [ text "Tailwind" ]
                    ]
                , div [ tw [ Tw.flex , Tw.gap6 ] ]
                    [ navLink "/" "Home"
                    , navLink "/getting-started" "Getting Started"
                    , navLink "/components" "Components"
                    ]
                ]
            ]
        ]

navLink url label =
    a
        [ href url
        , attribute "sky-nav" ""
        , tw
            [ Tw.textSm
            , Tw.fontMedium
            , Tw.textGray600
            , Tw.hover Tw.textBlue600
            , Tw.transitionColors
            , Tw.duration200
            ]
        ]
        [ text label ]

homeView model =
    div [] [ heroSection , featuresSection , liveDemo model , quickRefSection ]

heroSection =
    div [ tw [ Tw.bgWhite ] ]
        [ div
            [ tw [ Tw.maxW4xl , Tw.mxAuto , Tw.px6 , Tw.py24 , Tw.textCenter ] ]
            [ h1
                [ tw
                    [ Tw.text5xl
                    , Tw.fontExtrabold
                    , Tw.textGray900
                    , Tw.leadingTight
                    ]
                ]
                [ text "Type-safe styling" ]
            , h1
                [ tw
                    [ Tw.text5xl
                    , Tw.fontExtrabold
                    , Tw.textBlue600
                    , Tw.leadingTight
                    , Tw.mt2
                    ]
                ]
                [ text "for Sky apps" ]
            , p
                [ tw
                    [ Tw.mt6
                    , Tw.textXl
                    , Tw.textGray500
                    , Tw.maxW2xl
                    , Tw.mxAuto
                    , Tw.leadingRelaxed
                    ]
                ]
                [ text
                    "Tailwind-inspired utility functions that compile to type-checked Sky code. Autocomplete-friendly, composable, and zero runtime cost."
                ]
            , div [ tw [ Tw.mt8 , Tw.flex , Tw.justifyCenter , Tw.gap4 ] ]
                [ a
                    [ href "/getting-started"
                    , attribute "sky-nav" ""
                    , tw
                        [ Tw.bgBlue600
                        , Tw.hover Tw.bgBlue700
                        , Tw.textWhite
                        , Tw.fontSemibold
                        , Tw.py3
                        , Tw.px8
                        , Tw.roundedLg
                        , Tw.transitionColors
                        , Tw.duration200
                        , Tw.textCenter
                        , Tw.cursorPointer
                        ]
                    ]
                    [ text "Get Started" ]
                , a
                    [ href "/components"
                    , attribute "sky-nav" ""
                    , tw
                        [ Tw.bgWhite
                        , Tw.hover Tw.bgGray50
                        , Tw.textGray700
                        , Tw.fontSemibold
                        , Tw.py3
                        , Tw.px8
                        , Tw.roundedLg
                        , Tw.border
                        , Tw.borderGray300
                        , Tw.transitionColors
                        , Tw.duration200
                        , Tw.textCenter
                        , Tw.cursorPointer
                        ]
                    ]
                    [ text "See Components" ]
                ]
            ]
        ]

featuresSection =
    div [ tw [ Tw.py20 , Tw.px6 ] ]
        [ div [ tw [ Tw.maxW6xl , Tw.mxAuto ] ]
            [ h2
                [ tw
                    [ Tw.text3xl
                    , Tw.fontBold
                    , Tw.textCenter
                    , Tw.textGray900
                    , Tw.mb4
                    ]
                ]
                [ text "Why Sky-Tailwind?" ]
            , p
                [ tw
                    [ Tw.textCenter
                    , Tw.textGray500
                    , Tw.mb12
                    , Tw.maxW2xl
                    , Tw.mxAuto
                    ]
                ]
                [ text
                    "All the rapid prototyping power of Tailwind CSS, with the safety guarantees of the Sky compiler."
                ]
            , div
                [ tw [ Tw.grid , Tw.gridCols1 , Tw.md Tw.gridCols3 , Tw.gap8 ] ]
                [ featureCard "Compile-Time Safety"
                    "Every utility is a real function. Typos become compiler errors, not invisible bugs in production."
                , featureCard "Autocomplete Friendly"
                    "Import a module and let your editor show every available utility. No memorizing class name strings."
                , featureCard "Composable by Design"
                    "Utilities are values. Pass them to functions, build conditional lists, create your own component helpers."
                , featureCard "Responsive Wrappers"
                    "Apply any utility at any breakpoint with sm, md, lg, xl. Type-safe responsive design."
                , featureCard "State Variants"
                    "hover, focus, active, disabled — wrap any utility for interactive styles."
                , featureCard "Zero Runtime Cost"
                    "CSS is generated as a static string baked into your binary. No JavaScript, no CDN, no build step."
                ]
            ]
        ]

featureCard title_ description =
    div
        [ tw
            [ Tw.bgWhite
            , Tw.roundedXl
            , Tw.shadowMd
            , Tw.p6
            , Tw.hover Tw.shadowLg
            , Tw.transitionAll
            , Tw.duration300
            ]
        ]
        [ h3 [ tw [ Tw.textLg , Tw.fontSemibold , Tw.textGray900 , Tw.mb2 ] ]
            [ text title_ ]
        , p [ tw [ Tw.textSm , Tw.textGray600 , Tw.leadingRelaxed ] ]
            [ text description ]
        ]

