pricingDemo =
    div [ tw [ Tw.grid , Tw.gridCols1 , Tw.md Tw.gridCols3 , Tw.gap6 ] ]
        [ pricingCard "Starter" "Free" "0"
            [ "1 project" , "Basic utilities" , "Community support" ]
            False
        , pricingCard "Pro" "Popular" "29"
            [ "Unlimited projects"
            , "All utilities"
            , "Priority support"
            , "Custom themes"
            ]
            True
        , pricingCard "Enterprise" "" "99"
            [ "Unlimited everything"
            , "Custom builds"
            , "Dedicated support"
            , "SLA guarantee"
            , "Team training"
            ]
            False
        ]

pricingCard name badge price features highlighted =
    let
        cardStyle =
            if highlighted then
                [ Tw.bgBlue600
                , Tw.textWhite
                , Tw.roundedXl
                , Tw.shadow2xl
                , Tw.p8
                , Tw.scale105
                ]
            else
                [ Tw.bgWhite , Tw.roundedXl , Tw.shadowMd , Tw.p8 ]
        priceColor =
            if highlighted then
                Tw.textWhite
            else
                Tw.textGray900
        descColor =
            if highlighted then
                Tw.textBlue100
            else
                Tw.textGray500
        featureColor =
            if highlighted then
                Tw.textBlue100
            else
                Tw.textGray600
        btnStyle =
            if highlighted then
                [ Tw.bgWhite , Tw.textBlue600 , Tw.hover Tw.bgBlue50 ]
            else
                [ Tw.bgBlue600 , Tw.hover Tw.bgBlue700 , Tw.textWhite ]
    in
        div [ tw cardStyle ]
            [ div
                [ tw [ Tw.flex , Tw.justifyBetween , Tw.itemsCenter , Tw.mb4 ] ]
                [ h3 [ tw [ Tw.textXl , Tw.fontBold , priceColor ] ]
                    [ text name ]
                , badgeView badge
                ]
            , div [ tw [ Tw.mb6 ] ]
                [ span [ tw [ Tw.text4xl , Tw.fontExtrabold , priceColor ] ]
                    [ text ("$" ++ price) ]
                , span [ tw [ Tw.textSm , descColor ] ] [ text " / month" ]
                ]
            , ul [ tw [ Tw.mb8 ] ]
                (List.map (renderFeature featureColor) features)
            , button
                [ tw
                    (
                    btnStyle ++
                    [ Tw.wFull
                    , Tw.fontSemibold
                    , Tw.py3
                    , Tw.px6
                    , Tw.roundedLg
                    , Tw.transitionColors
                    , Tw.duration200
                    , Tw.cursorPointer
                    ]
                    )
                ]
                [ text "Get started" ]
            ]

badgeView badge =
    if badge == "" then
        text ""
    else
        span
            [ tw
                [ Tw.bgYellow400
                , Tw.textGray900
                , Tw.textXs
                , Tw.fontSemibold
                , Tw.py1
                , Tw.px2
                , Tw.roundedFull
                ]
            ]
            [ text badge ]

renderFeature featureColor f =
    li
        [ tw
            [ Tw.py2
            , Tw.textSm
            , featureColor
            , Tw.flex
            , Tw.itemsCenter
            , Tw.gap2
            ]
        ]
        [ span [] [ text f ] ]

statsDemo =
    div
        [ tw
            [ Tw.grid
            , Tw.gridCols1
            , Tw.sm Tw.gridCols2
            , Tw.lg Tw.gridCols4
            , Tw.gap6
            ]
        ]
        [ statCard "Total Users" "12,847"
        , statCard "Revenue" "$48,295"
        , statCard "Active Now" "342"
        , statCard "Bounce Rate" "2.4%"
        ]

statCard label_ value_ =
    div [ tw [ Tw.bgWhite , Tw.roundedXl , Tw.shadowMd , Tw.p6 ] ]
        [ p [ tw [ Tw.textSm , Tw.fontMedium , Tw.textGray500 , Tw.mb1 ] ]
            [ text label_ ]
        , p [ tw [ Tw.text3xl , Tw.fontBold , Tw.textGray900 ] ] [ text value_ ]
        ]

footer_ =
    div [ tw [ Tw.bgGray900 , Tw.mt20 ] ]
        [ div [ tw [ Tw.maxW6xl , Tw.mxAuto , Tw.px6 , Tw.py12 ] ]
            [ div
                [ tw [ Tw.grid , Tw.gridCols1 , Tw.md Tw.gridCols3 , Tw.gap8 ] ]
                [ div []
                    [ h3
                        [ tw [ Tw.textLg , Tw.fontBold , Tw.textWhite , Tw.mb4 ]
                        ]
                        [ text "Sky-Tailwind" ]
                    , p
                        [ tw [ Tw.textSm , Tw.textGray400 , Tw.leadingRelaxed ]
                        ]
                        [ text
                            "Type-safe Tailwind CSS utilities for the Sky programming language. Build beautiful, responsive UIs with compile-time safety."
                        ]
                    ]
                , div []
                    [ h3
                        [ tw
                            [ Tw.textSm
                            , Tw.fontSemibold
                            , Tw.textGray400
                            , Tw.uppercase
                            , Tw.trackingWider
                            , Tw.mb4
                            ]
                        ]
                        [ text "Modules" ]
                    , ul [ tw [ Tw.textSm , Tw.textGray400 ] ]
                        [ li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Spacing" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Typography" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Layout" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Flex" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Grid" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Background" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Border" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Tailwind.Effects" ]
                        ]
                    ]
                , div []
                    [ h3
                        [ tw
                            [ Tw.textSm
                            , Tw.fontSemibold
                            , Tw.textGray400
                            , Tw.uppercase
                            , Tw.trackingWider
                            , Tw.mb4
                            ]
                        ]
                        [ text "Resources" ]
                    , ul [ tw [ Tw.textSm , Tw.textGray400 ] ]
                        [ li [ tw [ Tw.mb2 ] ] [ text "Getting Started" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Component Gallery" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "Sky Language Docs" ]
                        , li [ tw [ Tw.mb2 ] ] [ text "GitHub Repository" ]
                        ]
                    ]
                ]
            , div [ tw [ Tw.borderT , Tw.borderGray800 , Tw.mt8 , Tw.pt8 ] ]
                [ p [ tw [ Tw.textSm , Tw.textGray500 , Tw.textCenter ] ]
                    [ text "Built with Sky and Sky-Tailwind" ]
                ]
            ]
        ]

main =
    app
        { init = init
        , update = update
        , view = view
        , subscriptions = subscriptions
        , routes =
            [ route "/" HomePage
            , route "/getting-started" GettingStartedPage
            , route "/components" ComponentsPage
            ]
        , notFound = HomePage
        }
