        [ div [ tw [ bgBlue50, border, borderBlue500, roundedLg, p4 ] ]
            [ p [ tw [ fontSemibold, textBlue700 ] ] [ text "Info" ]
            , p [ tw [ textSm, textBlue600, mt1 ] ]
                [ text "Sky-Tailwind utilities are compiled at build time. No runtime overhead." ]
