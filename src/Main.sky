-- Pricing Demo
pricingDemo =
    div [ tw [ grid, gridCols1, md gridCols3, gap6 ] ]
        [ pricingCard "Starter" "Free" "0"
            [ "1 project", "Basic utilities", "Community support" ]
            False
        , pricingCard "Pro" "Popular" "29"
            [ "Unlimited projects", "All utilities", "Priority support", "Custom themes" ]
            True
        , pricingCard "Enterprise" "" "99"
            [ "Unlimited everything", "Custom builds", "Dedicated support", "SLA guarantee", "Team training" ]
            False
        ]


pricingCard name badge price features highlighted =
    let
        cardStyle =
            if highlighted then
                [ bgBlue600, textWhite, roundedXl, shadow2xl, p8
                , scale105
                ]
            else
                [ bgWhite, roundedXl, shadowMd, p8 ]

        priceColor =
            if highlighted then textWhite else textGray900

        descColor =
            if highlighted then textBlue100 else textGray500

        featureColor =
            if highlighted then textBlue100 else textGray600

        btnStyle =
            if highlighted then
                [ bgWhite, textBlue600, hover bgBlue50 ]
            else
                [ bgBlue600, hover bgBlue700, textWhite ]
    in
    div [ tw cardStyle ]
        [ div [ tw [ flex, justifyBetween, itemsCenter, mb4 ] ]
            [ h3 [ tw [ textXl, fontBold, priceColor ] ] [ text name ]
            , if badge == "" then
                text ""
              else
                span [ tw [ bgYellow400, textGray900, textXs, fontSemibold, py1, px2, roundedFull ] ]
                    [ text badge ]
            ]
        , div [ tw [ mb6 ] ]
            [ span [ tw [ text4xl, fontExtrabold, priceColor ] ] [ text ("$" ++ price) ]
            , span [ tw [ textSm, descColor ] ] [ text " / month" ]
            ]
        , ul [ tw [ mb8 ] ]
            (features
                |> List.map (\f ->
                    li [ tw [ py2, textSm, featureColor, flex, itemsCenter, gap2 ] ]
                        [ span [] [ text f ] ]
                )
            )
        , button [ tw (btnStyle ++ [ wFull, fontSemibold, py3, px6, roundedLg
                                   , transitionColors, duration200, cursorPointer
                                   ]) ]
            [ text "Get started" ]
        ]


-- Stats Demo
statsDemo =
    div [ tw [ grid, gridCols1, sm gridCols2, lg gridCols4, gap6 ] ]
        [ statCard "Total Users" "12,847" "textBlue600" "bgBlue50"
        , statCard "Revenue" "$48,295" "textGreen600" "bgGreen50"
        , statCard "Active Now" "342" "textPurple600" "bgPurple50"
        , statCard "Bounce Rate" "2.4%" "textRed600" "bgRed50"
        ]


statCard label_ value_ colorClass bgClass =
    div [ tw [ bgWhite, roundedXl, shadowMd, p6 ] ]
        [ p [ tw [ textSm, fontMedium, textGray500, mb1 ] ]
            [ text label_ ]
        , p [ tw [ text3xl, fontBold, textGray900 ] ]
            [ text value_ ]
        ]


