module Main exposing (main)

import Sky.Core.List as List
import Sky.Core.String as String
import Std.Html exposing (..)
import Std.Html.Attributes exposing (..)
import Std.Live exposing (app, route)
import Std.Live.Events exposing (onClick)
import Std.Cmd as Cmd
import Std.Sub as Sub
import SkyTailwind exposing (styles, tw)
import SkyTailwind.Spacing exposing (..)
import SkyTailwind.Typography exposing (..)
import SkyTailwind.Layout exposing (..)
import SkyTailwind.Flex exposing (..)
import SkyTailwind.Grid exposing (..)
import SkyTailwind.Background exposing (..)
import SkyTailwind.Border exposing (..)
import SkyTailwind.Effects exposing (..)
import SkyTailwind.State exposing (hover, focus, active)
import SkyTailwind.Responsive exposing (sm, md, lg)


type Page
    = HomePage
    | GettingStartedPage
    | ComponentsPage


type alias Model =
    { page : Page
    , count : Int
    , navOpen : Bool
    }


type Msg
    = Navigate Page
    | Increment
    | Decrement
    | ToggleNav


init _ =
    ({ page = HomePage, count = 0, navOpen = False }, Cmd.none)


update msg model =
    case msg of
        Navigate p ->
            ({ model | page = p, navOpen = False }, Cmd.none)

        Increment ->
            ({ model | count = model.count + 1 }, Cmd.none)

        Decrement ->
            ({ model | count = model.count - 1 }, Cmd.none)

        ToggleNav ->
            ({ model | navOpen = not model.navOpen }, Cmd.none)


subscriptions _ =
    Sub.none


-- ============================================================
-- VIEWS
-- ============================================================

view model =
    div [ tw [ minHScreen, bgGray50, fontSans ] ]
        [ styles
        , navbar model
        , case model.page of
            HomePage ->
                homePage model

            GettingStartedPage ->
                gettingStartedPage

            ComponentsPage ->
                componentsPage model
        , footer_
        ]


-- ============================================================
-- NAVBAR
-- ============================================================

navbar model =
    nav [ tw [ bgWhite, shadowSm, sticky, top0, z50 ] ]
        [ div [ tw [ maxW6xl, mxAuto, px4, sm px6, lg px8 ] ]
            [ div [ tw [ flex, justifyBetween, itemsCenter, h16 ] ]
                [ a [ href "/", attribute "sky-nav" "" ]
                    [ span [ tw [ text2xl, fontBold, textBlue600 ] ]
                        [ text "Sky" ]
                    , span [ tw [ text2xl, fontLight, textGray400 ] ]
                        [ text "Tailwind" ]
                    ]
                , div [ tw [ hidden_, md flex, gap6 ] ]
                    [ navLink "/" "Home"
                    , navLink "/getting-started" "Getting Started"
                    , navLink "/components" "Components"
                    ]
                , button
                    [ tw [ md hidden_, p2, roundedMd, textGray600, hover bgGray100
                         , transitionColors
                         ]
                    , onClick "ToggleNav"
                    ]
                    [ text "Menu" ]
                ]
            ]
        ]


navLink url label =
    a [ href url
      , attribute "sky-nav" ""
      , tw [ textSm, fontMedium, textGray600, hover textBlue600
           , transitionColors, duration200
           ]
      ]
        [ text label ]


-- ============================================================
-- HOME PAGE
-- ============================================================

homePage model =
    div []
        [ heroSection
        , featuresSection
        , liveDemo model
        , quickRefSection
        ]


heroSection =
    div [ tw [ bgWhite ] ]
        [ div [ tw [ maxW4xl, mxAuto, px6, py24, textCenter ] ]
            [ h1 [ tw [ text5xl, md text6xl, fontExtrabold, textGray900, leadingTight ] ]
                [ text "Type-safe styling" ]
            , h1 [ tw [ text5xl, md text6xl, fontExtrabold, textBlue600, leadingTight, mt2 ] ]
                [ text "for Sky apps" ]
            , p [ tw [ mt6, textXl, textGray500, maxW2xl, mxAuto, leadingRelaxed ] ]
                [ text "Tailwind-inspired utility functions that compile to type-checked Sky code. Autocomplete-friendly, composable, and zero runtime cost." ]
            , div [ tw [ mt8, flex, justifyCenter, gap4, flexCol, sm flexRow ] ]
                [ a [ href "/getting-started"
                    , attribute "sky-nav" ""
                    , tw [ bgBlue600, hover bgBlue700, textWhite, fontSemibold
                         , py3, px8, roundedLg, transitionColors, duration200
                         , textCenter, cursorPointer
                         ]
                    ]
                    [ text "Get Started" ]
                , a [ href "/components"
                    , attribute "sky-nav" ""
                    , tw [ bgWhite, hover bgGray50, textGray700, fontSemibold
                         , py3, px8, roundedLg, border, borderGray300
                         , transitionColors, duration200
                         , textCenter, cursorPointer
                         ]
                    ]
                    [ text "See Components" ]
                ]
            ]
        ]


featuresSection =
    div [ tw [ py20, px6 ] ]
        [ div [ tw [ maxW6xl, mxAuto ] ]
            [ h2 [ tw [ text3xl, fontBold, textCenter, textGray900, mb4 ] ]
                [ text "Why Sky-Tailwind?" ]
            , p [ tw [ textCenter, textGray500, mb12, maxW2xl, mxAuto ] ]
                [ text "All the rapid prototyping power of Tailwind CSS, with the safety guarantees of the Sky compiler." ]
            , div [ tw [ grid, gridCols1, md gridCols3, gap8 ] ]
                [ featureCard
                    "Compile-Time Safety"
                    "Every utility is a real function. Typos become compiler errors, not invisible bugs in production."
                    "bgRed50"
                    "textRed700"
                , featureCard
                    "Autocomplete Friendly"
                    "Import a module and let your editor show every available utility. No memorizing class name strings."
                    "bgBlue50"
                    "textBlue700"
                , featureCard
                    "Composable by Design"
                    "Utilities are values. Pass them to functions, build conditional lists, create your own component helpers."
                    "bgGreen50"
                    "textGreen700"
                , featureCard
                    "Responsive Wrappers"
                    "Apply any utility at any breakpoint with sm, md, lg, xl. Type-safe responsive design."
                    "bgPurple50"
                    "textPurple700"
                , featureCard
                    "State Variants"
                    "hover, focus, active, disabled — wrap any utility for interactive styles."
                    "bgOrange50"
                    "textOrange700"
                , featureCard
                    "Zero Runtime Cost"
                    "CSS is generated as a static string baked into your binary. No JavaScript, no CDN, no build step."
                    "bgIndigo50"
                    "textIndigo700"
                ]
            ]
        ]


featureCard title_ description bgColor_ textColor_ =
    div [ tw [ bgWhite, roundedXl, shadowMd, p6
             , hover shadowLg, transitionAll, duration300
             ]
        ]
        [ h3 [ tw [ textLg, fontSemibold, textGray900, mb2 ] ]
            [ text title_ ]
        , p [ tw [ textSm, textGray600, leadingRelaxed ] ]
            [ text description ]
        ]


liveDemo model =
    div [ tw [ bgWhite, py20, px6 ] ]
        [ div [ tw [ maxW4xl, mxAuto ] ]
            [ h2 [ tw [ text3xl, fontBold, textCenter, textGray900, mb4 ] ]
                [ text "Live Interactive Demo" ]
            , p [ tw [ textCenter, textGray500, mb12 ] ]
                [ text "This counter is built entirely with Sky-Tailwind utilities. Try it!" ]
            , div [ tw [ bgGray50, roundedXl, p8, maxW2xl, mxAuto ] ]
                [ p [ tw [ text5xl, fontBold, textCenter, textGray900, mb8, fontMono ] ]
                    [ text (String.fromInt model.count) ]
                , div [ tw [ flex, justifyCenter, gap4 ] ]
                    [ button
                        [ tw [ bgRed500, hover bgRed600, textWhite, fontSemibold
                             , py3, px6, roundedLg, transitionColors, duration200
