            [ text "Yellow" ]
        , span [ tw [ bgIndigo100, textIndigo600, textXs, fontSemibold, py1, px3, roundedFull ] ]
            [ text "Indigo" ]
        , span [ tw [ bgPink100, textPink500, textXs, fontSemibold, py1, px3, roundedFull ] ]
            [ text "Pink" ]
        , span [ tw [ border, borderGray300, textGray600, textXs, fontSemibold, py1, px3, roundedFull ] ]
            [ text "Outlined" ]
        , span [ tw [ bgBlue600, textWhite, textXs, fontSemibold, py1, px3, rounded ] ]
            [ text "Square" ]
        ]


