componentsPage model =
    div [ tw [ maxW6xl, mxAuto, px6, py12 ] ]
        [ h1 [ tw [ text3xl, fontBold, textGray900, mb4 ] ]
            [ text "Component Gallery" ]
        , p [ tw [ textGray500, mb12, maxW2xl ] ]
            [ text "Example UI patterns built with Sky-Tailwind. Copy the code to use in your own projects." ]

        -- Buttons
        , componentSection "Buttons" buttonsDemo

        -- Cards
        , componentSection "Cards" cardsDemo

        -- Alerts
        , componentSection "Alerts" alertsDemo

        -- Navigation
        , componentSection "Badge & Tags" badgesDemo

        -- Form Inputs
        , componentSection "Form Elements" formsDemo

        -- Pricing
        , componentSection "Pricing Card" pricingDemo

        -- Stats
        , componentSection "Stats" statsDemo
        ]


componentSection title_ content =
    div [ tw [ mb16 ] ]
        [ h2 [ tw [ text2xl, fontSemibold, textGray900, mb6, pb2, borderB, borderGray200 ] ]
            [ text title_ ]
        , content
        ]


