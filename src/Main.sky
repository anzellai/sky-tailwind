            , codeBlock "-- The button above is just:\nbutton\n    [ tw [ bgGreen500, hover bgGreen600, textWhite, fontSemibold\n         , py3, px6, roundedLg, transitionColors, duration200\n         , cursorPointer, textLg\n         ]\n    , onClick \"Increment\"\n    ]\n    [ text \"+ Add\" ]"
            ]
        ]


