        [ div [ tw [ Tw.maxW6xl , Tw.mxAuto ] ]
            [ h2
                [ tw
                    [ Tw.text3xl
                    , Tw.fontBold
                    , Tw.textCenter
                    , Tw.textGray900
                    , Tw.mb4
                    ]
                ]
                [ text "Quick Reference" ]
            , p [ tw [ Tw.textCenter , Tw.textGray500 , Tw.mb12 ] ]
                [ text
                    "Each utility is a function returning a class attribute tuple."
                ]
            , div
                [ tw [ Tw.grid , Tw.gridCols1 , Tw.md Tw.gridCols2 , Tw.gap6 ] ]
                [ refCard "Import & Core"
                    [ "import Tailwind as Tw exposing (styles, tw)"
                    , "tw : List (String, String) -> (String, String)"
                    , "twWith : String -> List (...) -> (String, String)"
                    , "styles : VNode  -- place once in your view"
                    ]
                , refCard "Spacing"
                    [ "p0 .. p24, px0 .. px24, py0 .. py24"
                    , "pt, pr, pb, pl (each 0..8)"
                    , "m0 .. m24, mx0 .. mx8, my0 .. my8"
                    , "mt, mr, mb, ml (each 0..20)"
                    , "mxAuto, mlAuto, mrAuto, mAuto"
                    , "gap0 .. gap12"
                    ]
                , refCard "Typography"
                    [ "textXs .. text9xl"
                    , "fontThin .. fontBlack"
                    , "fontSans, fontSerif, fontMono"
                    , "textLeft, textCenter, textRight"
                    , "textBlack, textWhite, textGray50..900"
                    , "textRed/Blue/Green/Purple...500"
                    , "underline, lineThrough, noUnderline"
                    , "uppercase, lowercase, capitalize"
                    , "leadingNone .. leadingLoose"
                    , "trackingTighter .. trackingWidest"
                    ]
                , refCard "Layout"
                    [ "block, inline, inlineBlock, flex, grid"
                    , "hidden_, table_, tableRow, tableCell"
                    , "relative, absolute, fixed, sticky"
                    , "top0, right0, bottom0, left0, inset0"
                    , "z0, z10 .. z50, zAuto"
                    , "overflowAuto, overflowHidden, overflowScroll"
                    , "w0..w64, wFull, wScreen, wHalf, wThird"
                    , "h0..h64, hFull, hScreen"
                    , "maxWSm .. maxW7xl, minHScreen"
                    ]
                , refCard "Flexbox"
                    [ "flexRow, flexCol, flexRowReverse"
                    , "flexWrap, flexNowrap"
                    , "justifyStart/End/Center/Between/Around"
                    , "itemsStart/End/Center/Baseline/Stretch"
                    , "selfAuto/Start/End/Center/Stretch"
                    , "flex1, flexAuto, flexInitial, flexNone"
                    , "grow, grow0, shrink, shrink0"
                    , "order1..12, orderFirst, orderLast"
                    ]
                , refCard "Grid"
                    [ "gridCols1 .. gridCols12, gridColsNone"
                    , "gridRows1 .. gridRows6"
                    , "colSpan1 .. colSpan12, colSpanFull"
                    , "rowSpan1 .. rowSpan6, rowSpanFull"
                    , "gridFlowRow, gridFlowCol, gridFlowDense"
                    , "placeContentCenter, placeItemsCenter"
                    ]
                , refCard "Background"
                    [ "bgBlack, bgWhite, bgTransparent"
                    , "bgGray50..950, bgSlate50..900"
                    , "bgRed/Orange/Yellow/Green50..900"
                    , "bgBlue/Indigo/Purple/Pink50..700"
                    , "bgCover, bgContain, bgAuto"
                    , "bgCenter, bgTop, bgNoRepeat"
                    ]
                , refCard "Borders"
                    [ "border, border0, border2, border4"
                    , "borderT, borderR, borderB, borderL"
                    , "borderGray200..500, borderBlack/White"
                    , "borderSolid, borderDashed, borderDotted"
                    , "roundedNone .. roundedFull"
                    , "roundedSm, rounded, roundedMd, roundedLg"
                    , "ring, ring0, ring1, ring2, ring4"
                    ]
                , refCard "Effects"
                    [ "shadowSm, shadow, shadowMd .. shadow2xl"
                    , "opacity0 .. opacity100"
                    , "transition, transitionColors, transitionAll"
                    , "duration75 .. duration1000"
                    , "easeLinear, easeIn, easeOut, easeInOut"
                    , "scale0..150, rotate0..180"
                    , "cursorPointer, cursorNotAllowed, cursorGrab"
                    , "selectNone, pointerEventsNone"
                    ]
                , refCard "Responsive & State"
                    [ "Tw.sm, Tw.md, Tw.lg, Tw.xl, Tw.xxl"
                    , "  Usage: Tw.md Tw.textLg, Tw.lg Tw.gridCols3"
                    , "Tw.hover, Tw.focus, Tw.active, Tw.disabled"
                    , "Tw.firstChild, Tw.lastChild, Tw.odd, Tw.even"
                    , "  Usage: Tw.hover Tw.bgBlue700, Tw.focus Tw.ring2"
                    ]
                ]
            ]
        ]

refCard title_ items =
    let
        renderItem =
            \item -> li [ tw [ Tw.mb2 , Tw.leadingRelaxed ] ] [ text item ]
    in
        div [ tw [ Tw.bgWhite , Tw.roundedLg , Tw.shadow , Tw.p6 ] ]
            [ h3 [ tw [ Tw.fontSemibold , Tw.textGray900 , Tw.mb4 ] ]
                [ text title_ ]
            , ul [ tw [ Tw.textSm , Tw.fontMono , Tw.textGray600 ] ]
                (List.map renderItem items)
            ]

gettingStartedView =
    div [ tw [ Tw.maxW4xl , Tw.mxAuto , Tw.px6 , Tw.py12 ] ]
        [ h1 [ tw [ Tw.text3xl , Tw.fontBold , Tw.textGray900 , Tw.mb8 ] ]
            [ text "Getting Started" ]
        , section_ "1. Add to your project"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text "Add sky-tailwind as a dependency in your sky.toml:" ]
            , codeBlock
                "[dependencies]\n\"github.com/anzellai/sky-tailwind\" = \"latest\""
            ]
        , section_ "2. Import Tailwind"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "One import gives you access to every utility via the Tw. prefix:"
                ]
            , codeBlock "import Tailwind as Tw exposing (styles, tw)"
            , p [ tw [ Tw.textGray600 , Tw.mt4 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "Or import individual submodules if you prefer granular control:"
                ]
            , codeBlock
                "import Tailwind.Spacing exposing (p4, mt2, gap4)\nimport Tailwind.Typography exposing (textLg, fontBold)"
            ]
        , section_ "3. Add the styles node to your view"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "Place the styles VNode once in your top-level view. This injects all the CSS rules:"
                ]
            , codeBlock
                "view model =\n    div []\n        [ styles    -- inject CSS, place once at top level\n        , h1 [] [ text \"Hello!\" ]\n        ]"
            ]
        , section_ "4. Compose utilities with tw"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "The tw function merges a list of utilities into a single class attribute:"
                ]
            , codeBlock
                "button\n    [ tw [ Tw.bgBlue500, Tw.textWhite, Tw.fontBold, Tw.py2, Tw.px4, Tw.roundedLg ] ]\n    [ text \"Click me\" ]"
            , p [ tw [ Tw.textGray600 , Tw.mt4 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text "For a single utility, use it directly as an attribute:"
                ]
            , codeBlock "div [ Tw.p4 ] [ text \"Just padding\" ]"
            ]
        , section_ "5. Responsive design"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text "Wrap any utility with a breakpoint function:" ]
            , codeBlock
                "div [ tw [ Tw.p4, Tw.md Tw.p8, Tw.lg Tw.p12 ] ]\n    [ text \"Padding grows with screen size\" ]\n\ndiv [ tw [ Tw.gridCols1, Tw.md Tw.gridCols2, Tw.lg Tw.gridCols4, Tw.gap4 ] ]\n    [ text \"Responsive grid\" ]"
            , div
                [ tw [ Tw.bgBlue50 , Tw.roundedLg , Tw.p4 , Tw.mt4 , Tw.mb4 ] ]
                [ p [ tw [ Tw.textSm , Tw.textBlue700 ] ]
                    [ text
                        "Breakpoints: sm = 640px, md = 768px, lg = 1024px, xl = 1280px, xxl = 1536px"
                    ]
                ]
            ]
        , section_ "6. Interactive states"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "Wrap a utility with hover, focus, active, or disabled to apply it on that state:"
                ]
            , codeBlock
                "button\n    [ tw [ Tw.bgBlue500, Tw.hover Tw.bgBlue700, Tw.focus Tw.ring2\n         , Tw.active Tw.scale95, Tw.transitionAll, Tw.duration200\n         ]\n    ]\n    [ text \"Interactive button\" ]"
            , p [ tw [ Tw.textGray600 , Tw.mt4 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "This works because hover, focus, etc. are higher-order functions that prefix the class name."
                ]
            ]
        , section_ "7. Conditional styling"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "Since tw takes a List, conditional styling is just list manipulation:"
                ]
            , codeBlock
                "div [ tw ([ Tw.p4, Tw.rounded, Tw.textWhite ]\n    ++ (if model.active\n        then [ Tw.bgGreen500 ]\n        else [ Tw.bgGray400 ])\n    ) ]\n    [ text \"Conditional background\" ]"
            ]
        , section_ "8. Mixing with custom classes"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "Use twWith to merge sky-tailwind utilities with additional custom class names:"
                ]
            , codeBlock
                "div [ twWith \"my-custom-class\" [ Tw.p4, Tw.bgWhite, Tw.roundedLg ] ]\n    [ text \"Sky-Tailwind + custom\" ]"
            ]
        , section_ "9. Building reusable components"
            [ p [ tw [ Tw.textGray600 , Tw.mb4 , Tw.leadingRelaxed ] ]
                [ text
                    "Extract styled elements into functions — the Sky-Tailwind way of building a design system:"
                ]
            , codeBlock
                "primaryBtn label msg =\n    button\n        [ tw [ Tw.bgBlue600, Tw.hover Tw.bgBlue700, Tw.textWhite\n             , Tw.fontSemibold, Tw.py2, Tw.px6, Tw.roundedLg\n             ]\n        , onClick msg\n        ]\n        [ text label ]\n\ncard title_ body =\n    div [ tw [ Tw.bgWhite, Tw.roundedXl, Tw.shadowMd, Tw.p6 ] ]\n        [ h3 [ tw [ Tw.textLg, Tw.fontSemibold, Tw.mb2 ] ]\n            [ text title_ ]\n        , p [ tw [ Tw.textSm, Tw.textGray600 ] ]\n            [ text body ]\n        ]"
            ]
        ]

section_ title_ content =
    let
        header =
            h2
                [ tw
                    [ Tw.text2xl
                    , Tw.fontSemibold
                    , Tw.textGray900
                    , Tw.mb4
                    , Tw.mt4
                    ]
                ]
                [ text title_ ]
        children =
            [ header ] ++ content
    in
        div [ tw [ Tw.mb12 ] ] children

codeBlock code =
    pre
        [ tw
            [ Tw.bgGray900
            , Tw.textGray100
            , Tw.p6
            , Tw.roundedLg
            , Tw.overflowXAuto
            , Tw.textSm
            , Tw.fontMono
            , Tw.leadingRelaxed
            , Tw.mt4
            , Tw.mb4
            ]
        ]
        [ codeNode [] [ text code ] ]

componentsView model =
    div [ tw [ Tw.maxW6xl , Tw.mxAuto , Tw.px6 , Tw.py12 ] ]
        [ h1 [ tw [ Tw.text3xl , Tw.fontBold , Tw.textGray900 , Tw.mb4 ] ]
            [ text "Component Gallery" ]
        , p [ tw [ Tw.textGray500 , Tw.mb12 , Tw.maxW2xl ] ]
            [ text
                "Example UI patterns built with Sky-Tailwind. Copy the code to use in your own projects."
            ]
        , componentSection "Buttons" buttonsDemo
        , componentSection "Cards" cardsDemo
        , componentSection "Alerts" alertsDemo
        , componentSection "Badges" badgesDemo
        , componentSection "Form Elements" formsDemo
        , componentSection "Pricing Card" pricingDemo
        , componentSection "Stats" statsDemo
        ]

