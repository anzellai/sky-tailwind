cardsDemo =
    div [ tw [ Tw.grid , Tw.gridCols1 , Tw.md Tw.gridCols3 , Tw.gap6 ] ]
        [ div
            [ tw
                [ Tw.bgWhite
                , Tw.roundedXl
                , Tw.shadowMd
                , Tw.overflowHidden
                , Tw.hover Tw.shadowLg
                , Tw.transitionAll
                , Tw.duration300
                ]
            ]
            [ div [ tw [ Tw.h48 , Tw.bgBlue500 ] ] []
            , div [ tw [ Tw.p6 ] ]
                [ h3
                    [ tw
                        [ Tw.fontSemibold
                        , Tw.textLg
                        , Tw.textGray900
                        , Tw.mb2
                        ]
                    ]
                    [ text "Card with Image" ]
                , p [ tw [ Tw.textSm , Tw.textGray600 , Tw.leadingRelaxed ] ]
                    [ text
                        "A card with a colored header area that could hold an image or illustration."
                    ]
                ]
            ]
        , div
            [ tw
                [ Tw.bgWhite
                , Tw.roundedXl
                , Tw.shadowMd
                , Tw.p6
                , Tw.borderL
                , Tw.border4
                , Tw.hover Tw.shadowLg
                , Tw.transitionAll
                , Tw.duration300
                ]
            ]
            [ h3
                [ tw [ Tw.fontSemibold , Tw.textLg , Tw.textGray900 , Tw.mb2 ] ]
                [ text "Left Border Accent" ]
            , p [ tw [ Tw.textSm , Tw.textGray600 , Tw.leadingRelaxed ] ]
                [ text
                    "A card with a left border accent. Great for callouts and highlighted content."
                ]
            ]
        , div
            [ tw
                [ Tw.bgGray900
                , Tw.roundedXl
                , Tw.shadowMd
                , Tw.p6
                , Tw.hover Tw.shadowLg
                , Tw.transitionAll
                , Tw.duration300
                ]
            ]
            [ h3 [ tw [ Tw.fontSemibold , Tw.textLg , Tw.textWhite , Tw.mb2 ] ]
                [ text "Dark Card" ]
            , p [ tw [ Tw.textSm , Tw.textGray400 , Tw.leadingRelaxed ] ]
                [ text
                    "A dark themed card for contrast sections. Works great for CTAs."
                ]
            , button
                [ tw
                    [ Tw.mt4
                    , Tw.bgWhite
                    , Tw.textGray900
                    , Tw.fontSemibold
                    , Tw.py2
                    , Tw.px4
                    , Tw.roundedLg
                    , Tw.textSm
                    , Tw.transitionColors
                    , Tw.duration200
                    , Tw.cursorPointer
                    ]
                ]
                [ text "Learn more" ]
            ]
        ]

