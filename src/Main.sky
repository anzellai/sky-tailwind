        , div [ tw [ bgGreen50, border, borderGreen500, roundedLg, p4 ] ]
            [ p [ tw [ fontSemibold, textGreen700 ] ] [ text "Success" ]
            , p [ tw [ textSm, textGreen600, mt1 ] ]
                [ text "Your project has been deployed successfully." ]
